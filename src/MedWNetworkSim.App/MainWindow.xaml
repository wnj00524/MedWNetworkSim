<Window x:Class="MedWNetworkSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        xmlns:local="clr-namespace:MedWNetworkSim.App"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding WindowTitle}"
        Width="1680"
        Height="1040"
        MinWidth="1380"
        MinHeight="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,24,0">
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentStrongBrush}"
                               Text="World Systems Builder" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding ActiveWorldLabel}" />
                    <Border Margin="0,10,0,0"
                            Padding="10,8"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <WrapPanel>
                            <CheckBox Content="Worldbuilding language"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Foreground="{DynamicResource AccentStrongBrush}"
                                      IsChecked="{Binding IsWorldbuilderMode, Mode=TwoWay}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Build places, routes, and flows first. Use advanced controls when the model needs detail." />
                        </WrapPanel>
                    </Border>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           ItemWidth="Auto"
                            Margin="0,-4,0,0">
                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="START" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="New World" Click="NewNetwork_Click" />
                                <Button Content="Open World..." Click="OpenFile_Click" />
                            </WrapPanel>
                            <WrapPanel Margin="0,8,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Example" />
                                <ComboBox Width="260"
                                          Margin="0,0,10,0"
                                          DisplayMemberPath="DisplayLabel"
                                          ItemsSource="{Binding WorldbuilderScenarioOptions}"
                                          SelectedItem="{Binding SelectedWorldbuilderScenario, Mode=TwoWay}" />
                                <Button Content="Start From Example"
                                        Click="LoadWorldbuilderScenario_Click" />
                            </WrapPanel>
                            <WrapPanel Margin="0,8,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Template" />
                                <ComboBox Width="190"
                                          Margin="0,0,10,0"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding PlaceTemplateOptions}"
                                          SelectedItem="{Binding SelectedPlaceTemplate, Mode=TwoWay}" />
                                <Button Content="Start From Template"
                                        Click="AddNodeFromTemplate_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="ADVANCED" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Properties..."
                                        Click="NetworkProperties_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Save JSON..."
                                        Click="SaveFile_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Quick Save"
                                        Click="QuickSave_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="GraphML..."
                                        Click="GraphMl_Click" />
                                <Button Content="Export..."
                                        Click="Reports_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Fit Map"
                                        Click="AutoArrange_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                            <WrapPanel Margin="0,8,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Theme" />
                                <ComboBox Width="140"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Margin="12,0,0,0"
                                          VerticalAlignment="Center"
                                          Content="Loop"
                                          FontSize="11"
                                          Foreground="{DynamicResource MutedForegroundBrush}"
                                          IsChecked="{Binding IsTimelineLoopEnabled, Mode=TwoWay}" />
                                <TextBox Width="56"
                                         Margin="8,0,0,0"
                                         IsEnabled="{Binding IsTimelineLoopEnabled}"
                                         Background="{DynamicResource InputBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Text="{Binding TimelineLoopLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Workspace" />
                            <WrapPanel Margin="0,8,0,0">
                                <ToggleButton Content="{Binding CanvasOnlyButtonLabel}"
                                              Click="ToggleCanvasOnly_Click"
                                              IsChecked="{Binding IsCanvasOnlyMode, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Layers"
                                              Click="ToggleLayers_Click"
                                              IsChecked="{Binding IsLayersPanelOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Inspector"
                                              Click="ToggleInspector_Click"
                                              IsChecked="{Binding InspectorPanel.IsOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Reports"
                                              Click="ToggleReportsDrawer_Click"
                                              IsChecked="{Binding ReportsDrawer.IsOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Legend"
                                              Click="ToggleLegend_Click"
                                              IsChecked="{Binding IsLegendPanelOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Fit"
                                        Click="AutoArrange_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Simulation" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Run Simulation"
                                        Click="RunSimulation_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Reset Timeline"
                                        Click="ResetTimeline_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Next Period"
                                        Click="NextTimelinePeriod_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                            <local:TimelineToolbarControl Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,0,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Appearance" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Theme" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <CheckBox Margin="0,8,0,0"
                                      Content="Worldbuilder mode"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Foreground="{DynamicResource AccentStrongBrush}"
                                      IsChecked="{Binding IsWorldbuilderMode, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding DataContext.RightRailSpacerColumnWidth, ElementName=RootWindow}" />
                <ColumnDefinition Width="{Binding DataContext.RightRailColumnWidth, ElementName=RootWindow}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="20"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentStrongBrush}"
                                           Text="Build / Simulate / Analyze" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="{Binding StatusMessage}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center">
                                <Button Content="{Binding Terminology.AddNodeButton}"
                                        Click="AddNode_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="{Binding Terminology.Edges, StringFormat=Connect {0}...}"
                                        Click="EditEdges_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="{Binding Terminology.TrafficTypes, StringFormat=Define {0}...}"
                                        Click="EditTrafficTypes_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Run"
                                        Click="RunSimulation_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Next Period"
                                        Click="NextTimelinePeriod_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Layers"
                                              Click="ToggleLayers_Click"
                                              IsChecked="{Binding IsLayersPanelOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Inspector"
                                              Click="ToggleInspector_Click"
                                              IsChecked="{Binding InspectorPanel.IsOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Reports"
                                              Click="ToggleReportsDrawer_Click"
                                              IsChecked="{Binding ReportsDrawer.IsOpen, Mode=OneWay}"
                                              IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="NetworkCanvasScrollViewer"
                                  Grid.Row="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <Grid x:Name="NetworkCanvasGrid"
                              Width="{Binding WorkspaceWidth}"
                              Height="{Binding WorkspaceHeight}"
                              PreviewMouseLeftButtonDown="NetworkCanvasGrid_OnPreviewMouseLeftButtonDown"
                              PreviewMouseRightButtonDown="NetworkCanvasGrid_OnPreviewMouseRightButtonDown"
                              PreviewMouseWheel="NetworkCanvasGrid_OnPreviewMouseWheel">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="NetworkCanvasScaleTransform"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Grid.LayoutTransform>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.Terminology.AddNodeButton, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Click="CanvasAddNode_Click" />
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <Border Background="{DynamicResource CanvasGridBrush}"
                                    BorderBrush="{DynamicResource CanvasLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20" />

                            <Line x:Name="EdgeCreationPreviewLine"
                                  IsHitTestVisible="False"
                                  Stroke="{DynamicResource AccentStrongBrush}"
                                  StrokeThickness="3"
                                  StrokeDashArray="6,4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />

                            <ItemsControl ItemsSource="{Binding Edges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <Canvas Width="{Binding DataContext.WorkspaceWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Height="{Binding DataContext.WorkspaceHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{DynamicResource EdgeBrush}"
                                                  StrokeThickness="2.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.72"
                                                  MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                  ToolTip="{Binding EdgeToolTipText}"
                                                  Visibility="{Binding EdgeVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="Transparent"
                                                  StrokeThickness="18"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                  ToolTip="{Binding EdgeToolTipText}"
                                                  Visibility="{Binding EdgeVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{Binding FlowStrokeBrush}"
                                                  StrokeThickness="{Binding FlowStrokeThickness}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.92"
                                                  MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                  ToolTip="{Binding EdgeToolTipText}"
                                                  Visibility="{Binding FlowOverlayVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{DynamicResource AccentStrongBrush}"
                                                  StrokeThickness="{Binding RouteHighlightStrokeThickness}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.78"
                                                  Visibility="{Binding RouteHighlightVisibility}" />

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{DynamicResource EdgeBrush}"
                                                     Visibility="{Binding ArrowVisibility}" />

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{Binding FlowStrokeBrush}"
                                                     Opacity="0.92"
                                                     Visibility="{Binding FlowArrowVisibility}" />

                                            <Border Canvas.Left="{Binding LabelLeft}"
                                                    Canvas.Top="{Binding LabelTop}"
                                                    Width="{Binding LabelWidth}"
                                                    Height="{Binding LabelHeight}"
                                                    Padding="8,4"
                                                    Background="{DynamicResource EdgeLabelBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Opacity="0.9"
                                                    MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                    ToolTip="{Binding EdgeToolTipText}"
                                                    Visibility="{Binding EdgeVisibility}">
                                                <StackPanel>
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentStrongBrush}"
                                                               Text="{Binding RouteSummaryLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="{Binding RouteDetailLabel}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding TechnicalLabelVisibility}" />
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding FlowStrokeBrush}"
                                                               Text="{Binding FlowSummaryLabel}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding FlowSummaryVisibility}" />
                                                </StackPanel>
                                            </Border>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding Nodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                        <Thumb Width="{Binding Width}"
                                               Height="{Binding Height}"
                                               Cursor="SizeAll"
                                               PreviewMouseLeftButtonDown="NodeThumb_OnPreviewMouseLeftButtonDown"
                                               PreviewMouseLeftButtonUp="NodeThumb_OnPreviewMouseLeftButtonUp"
                                               DragDelta="NodeThumb_OnDragDelta"
                                               ToolTip="{Binding FullTrafficSummary}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid>
                                                        <Border Padding="12"
                                                                Background="{DynamicResource NodeBrush}"
                                                                BorderBrush="{Binding NodeBorderDisplayBrush}"
                                                                BorderThickness="1.4"
                                                                CornerRadius="{Binding NodeCornerRadius}"
                                                                Visibility="{Binding SquareNodeVisibility}" />
                                                        <Ellipse Fill="{DynamicResource NodeBrush}"
                                                                 Stroke="{Binding NodeBorderDisplayBrush}"
                                                                 StrokeThickness="1.4"
                                                                 Visibility="{Binding CircularNodeVisibility}" />
                                                        <Viewbox Visibility="{Binding OutlineShapeVisibility}"
                                                                 IsHitTestVisible="False">
                                                            <Path Data="{Binding ShapeIconGeometry}"
                                                                  Fill="{DynamicResource NodeBrush}"
                                                                  Stroke="{Binding NodeBorderDisplayBrush}"
                                                                  StrokeThickness="1.4"
                                                                  Stretch="Uniform" />
                                                        </Viewbox>
                                                        <Grid Margin="12,10">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Row="1"
                                                                       Margin="0,2,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                                       Text="{Binding PlaceTypeLabel}"
                                                                       TextTrimming="CharacterEllipsis" />

                                                            <ItemsControl Grid.Row="2"
                                                                          Margin="0,8,0,0"
                                                                          ItemsSource="{Binding RoleBadges}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="0,0,5,5"
                                                                                Padding="7,2"
                                                                                Background="{DynamicResource CardAltBrush}"
                                                                                CornerRadius="8">
                                                                            <TextBlock FontSize="10"
                                                                                       FontWeight="SemiBold"
                                                                                       Text="{Binding}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <StackPanel Grid.Row="3">
                                                                <TextBlock FontSize="10"
                                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                                           Text="{Binding CompactFlowSummary}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding SimulationBrush}"
                                                                           Text="{Binding FlowSummaryLabel}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Visibility="{Binding SimulationPanelVisibility}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource AccentStrongBrush}"
                                                                           Text="{Binding TimelineSummaryLabel}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Visibility="{Binding TimelinePanelVisibility}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding DataContext.RightRailVisibility, ElementName=RootWindow}">
                <StackPanel>
                    <local:LayersPanelControl DataContext="{Binding LayersPanel}"
                                              Visibility="{Binding LayersPanelVisibility}" />
                    <local:InspectorPanelControl Margin="0,14,0,0"
                                                 DataContext="{Binding InspectorPanel}"
                                                 Visibility="{Binding InspectorPanel.Visibility}" />
                    <local:LegendPanelControl Margin="0,14,0,0"
                                              Visibility="{Binding LegendPanelVisibility}" />
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <Border Grid.Row="2"
                Padding="18"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                MaxHeight="360"
                Visibility="{Binding DataContext.BottomWorkspaceVisibility, ElementName=RootWindow}">
            <local:ReportsDrawerControl />
        </Border>
    </Grid>
</Window>
