<UserControl x:Class="MedWNetworkSim.App.LegendPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Legend" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Thicker edges carry more visible flow. Green, amber, and red overlays indicate increasing capacity utilisation. Highlighted traffic layers stay visible while the combined aggregate remains as context."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0"
                       FontWeight="SemiBold"
                       Text="Node badges" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Node cards summarize producers, consumers, stores, transhipment hubs, inventory, backlog, and capacity stress when those overlays are enabled."
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
