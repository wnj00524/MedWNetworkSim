<Window x:Class="MedWNetworkSim.App.NodeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        mc:Ignorable="d"
        Title="Node Editor"
        Width="820"
        Height="680"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Node Editor" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Choose a node, set any shared transhipment capacity, then choose one of its traffic-role entries and set the traffic type and role from dropdown lists. You can also bulk-apply one traffic role to every node from this window."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Node Details" />

                    <WrapPanel Grid.Row="2">
                        <Button Content="Add Node" Click="AddNode_Click" />
                        <Button Content="Remove Selected" Click="RemoveNode_Click" />
                    </WrapPanel>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Node" />
                        <ComboBox Grid.Column="1"
                                  MinWidth="220"
                                  ItemsSource="{Binding Nodes}"
                                  SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                    <TextBlock>
                                        <Run Text="{Binding Name}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding Id}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Id" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,0,0,0"
                                 Text="{Binding SelectedNode.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Name" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Text="{Binding SelectedNode.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Shape" />
                        <ComboBox Grid.Row="6"
                                  Grid.Column="1"
                                  ItemsSource="{Binding SelectedNodeShapeOptions}"
                                  SelectedItem="{Binding SelectedNodeShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="8"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Transhipment Capacity" />
                        <TextBox Grid.Row="8"
                                 Grid.Column="1"
                                 Text="{Binding SelectedNode.TranshipmentCapacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="10" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="X" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedNode.X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Y" />
                            <TextBox Grid.Column="4"
                                     Text="{Binding SelectedNode.Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Grid>

                    <Border Grid.Row="6"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Tip: select a node on the canvas or in the main node table, then use this window to manage its traffic-role entries with dropdowns."
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Traffic Role Entry" />

                    <WrapPanel Grid.Row="2">
                        <Button Content="Add Traffic Role" Click="AddTrafficRole_Click" />
                        <Button Content="Apply To All Nodes..." Click="ApplyTrafficRoleToAllNodes_Click" />
                        <Button Content="Remove Selected" Click="RemoveTrafficRole_Click" />
                    </WrapPanel>

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Entry" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="260"
                                      ItemsSource="{Binding SelectedNode.TrafficProfiles}"
                                      SelectedItem="{Binding SelectedNodeTrafficProfile, Mode=TwoWay}"
                                      DisplayMemberPath="SelectionLabel" />

                            <TextBlock Grid.Row="2"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Traffic Type" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      ItemsSource="{Binding TrafficTypeNameOptions}"
                                      SelectedItem="{Binding SelectedNodeTrafficType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Role" />
                            <ComboBox Grid.Row="4"
                                      Grid.Column="1"
                                      ItemsSource="{Binding SelectedNodeRoleOptions}"
                                      SelectedItem="{Binding SelectedNodeRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="6"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Production" />
                            <TextBox Grid.Row="6"
                                     Grid.Column="1"
                                     IsEnabled="{Binding IsSelectedNodeProducer}"
                                     Text="{Binding SelectedNodeProduction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="8"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Consumption" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     IsEnabled="{Binding IsSelectedNodeConsumer}"
                                     Text="{Binding SelectedNodeConsumption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="10"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Consumer Premium / Unit" />
                            <TextBox Grid.Row="10"
                                     Grid.Column="1"
                                     IsEnabled="{Binding IsSelectedNodeConsumer}"
                                     Text="{Binding SelectedNodeConsumerPremiumPerUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Grid.Row="12" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Prod From" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedNodeProductionStartPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="To" />
                            <TextBox Grid.Column="4"
                                     Text="{Binding SelectedNodeProductionEndPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Grid.Row="14" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Cons From" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedNodeConsumptionStartPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="To" />
                            <TextBox Grid.Column="4"
                                     Text="{Binding SelectedNodeConsumptionEndPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Grid.Row="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox VerticalAlignment="Center"
                                          Content="Store"
                                          IsChecked="{Binding IsSelectedNodeStore, Mode=TwoWay}" />
                                <TextBox Grid.Column="1"
                                         Margin="12,0,0,0"
                                         IsEnabled="{Binding IsSelectedNodeStore}"
                                         Text="{Binding SelectedNodeStoreCapacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <GroupBox Grid.Row="18"
                                      Grid.ColumnSpan="2"
                                      Header="Production Windows">
                                <StackPanel Margin="8">
                                    <ItemsControl ItemsSource="{Binding SelectedNodeTrafficProfile.ProductionWindows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            Content="Remove"
                                                            Click="RemoveProductionWindow_Click" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="From" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding StartPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="To" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding EndPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button HorizontalAlignment="Left"
                                            Content="Add production window"
                                            Click="AddProductionWindow_Click" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="20"
                                      Grid.ColumnSpan="2"
                                      Header="Consumption Windows">
                                <StackPanel Margin="8">
                                    <ItemsControl ItemsSource="{Binding SelectedNodeTrafficProfile.ConsumptionWindows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            Content="Remove"
                                                            Click="RemoveConsumptionWindow_Click" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="From" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding StartPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="To" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding EndPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button HorizontalAlignment="Left"
                                            Content="Add consumption window"
                                            Click="AddConsumptionWindow_Click" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="22"
                                      Grid.ColumnSpan="2"
                                      Header="Production Inputs">
                                <StackPanel Margin="8">
                                    <ItemsControl ItemsSource="{Binding SelectedNodeTrafficProfile.InputRequirements}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            Content="Remove"
                                                            Click="RemoveInputRequirement_Click" />
                                                    <ComboBox Width="130"
                                                              ItemsSource="{Binding DataContext.TrafficTypeNameOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding TrafficType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Margin="8,0,6,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="per output" />
                                                    <TextBox Width="70"
                                                             Text="{Binding QuantityPerOutputUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button HorizontalAlignment="Left"
                                            Content="Add input"
                                            Click="AddInputRequirement_Click" />
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="6"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="{Binding SelectedNodeTrafficSelectionLabel}" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding SelectedNodeTrafficRoleSummary}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="{Binding StatusMessage}" />
            <Button DockPanel.Dock="Right"
                    Margin="12,0,0,0"
                    Content="Close"
                    Click="Close_Click" />
        </DockPanel>
    </Grid>
</Window>
