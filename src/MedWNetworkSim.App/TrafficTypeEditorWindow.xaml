<Window x:Class="MedWNetworkSim.App.TrafficTypeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Terminology.TrafficTypeEditorTitle}"
        Style="{StaticResource DialogChromeWindowStyle}"
        Width="980"
        Height="700"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="AccessibleEditorButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="KeyboardNavigation.IsTabStop" Value="True" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                           Text="{Binding Terminology.TrafficTypeEditorTitle}" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HelperTextStyle}"
                           Text="{Binding Terminology.TrafficTypeEditorIntro}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                               Text="{Binding Terminology.TrafficTypes}" />

                    <WrapPanel Grid.Row="2">
                        <Button Content="{Binding Terminology.AddTrafficTypeButton}"
                                Click="AddTrafficType_Click"
                                Style="{StaticResource AccessibleEditorButtonStyle}"
                                ToolTip="Add a new traffic type" />
                        <Button Content="Remove selected traffic type"
                                Click="RemoveTrafficType_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Remove the selected traffic type" />
                    </WrapPanel>

                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding TrafficDefinitions}"
                              SelectedItem="{Binding SelectedTrafficDefinition, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              MinHeight="360"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Name" Width="130" />
                            <DataGridTemplateColumn Header="Preference" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding RoutingPreference}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="112"
                                                  ItemsSource="{Binding DataContext.RoutingPreferences, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding RoutingPreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Allocation Mode" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding AllocationModeLabel}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="170"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  ItemsSource="{Binding DataContext.AllocationModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding AllocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding CapacityBidPerUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Header="Bid / Unit" Width="105" />
                            <DataGridTextColumn Binding="{Binding PerishabilityPeriods, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Perish (Periods)" Width="120" />
                            <DataGridTemplateColumn Header="Route Model" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding RouteChoiceModel}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="160"
                                                  ItemsSource="{Binding DataContext.RouteChoiceModels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding RouteChoiceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Split Policy" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding FlowSplitPolicy}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="120"
                                                  ItemsSource="{Binding DataContext.FlowSplitPolicies, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding FlowSplitPolicy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Description" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                               Text="{Binding Terminology.SelectedTrafficTypeHeader}" />

                    <StackPanel Grid.Row="2">
                        <Border Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                           Text="{Binding Terminology.TrafficType}" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding SelectedTrafficDefinition.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Description" />
                                <TextBox Margin="0,6,0,0"
                                         MinHeight="90"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding SelectedTrafficDefinition.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                           Text="Network flow" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="Set how this traffic values routes, how it allocates flow, and whether it competes for capacity." />

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Preference" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding RoutingPreferences}"
                                          SelectedItem="{Binding SelectedTrafficDefinition.RoutingPreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Allocation mode" />
                                <ComboBox Margin="0,6,0,0"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding AllocationModeOptions}"
                                          SelectedValue="{Binding SelectedTrafficDefinition.AllocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding SelectedTrafficDefinition.AllocationModeHelpText}" />

                                <UniformGrid Margin="0,12,0,0"
                                             Columns="2">
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="Bid per unit" />
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding SelectedTrafficDefinition.CapacityBidPerUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="Perishability (periods)" />
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding SelectedTrafficDefinition.PerishabilityPeriods, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                           Text="Route choice" />

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Route model" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding RouteChoiceModels}"
                                          SelectedItem="{Binding SelectedTrafficDefinition.RouteChoiceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding SelectedTrafficDefinition.RouteChoiceModelHelpText}" />

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Flow split" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding FlowSplitPolicies}"
                                          SelectedItem="{Binding SelectedTrafficDefinition.FlowSplitPolicy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding SelectedTrafficDefinition.FlowSplitPolicyHelpText}" />

                                <UniformGrid Margin="0,12,0,0"
                                             Columns="2">
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="Candidate routes" />
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding SelectedTrafficDefinition.MaxCandidateRoutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="Priority" />
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding SelectedTrafficDefinition.Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Congestion sensitivity" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding SelectedTrafficDefinition.CongestionSensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                           Text="Advanced behaviour" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="These settings matter most for adaptive or centrally managed traffic types." />

                                <StackPanel Visibility="{Binding SelectedTrafficDefinition.IsStochasticUserResponsive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <UniformGrid Margin="0,12,0,0"
                                                 Columns="2">
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Information accuracy" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding SelectedTrafficDefinition.InformationAccuracy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Route diversity" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding SelectedTrafficDefinition.RouteDiversity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Margin="0,12,0,0"
                                                 Columns="2">
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Reroute threshold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding SelectedTrafficDefinition.RerouteThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Stickiness" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding SelectedTrafficDefinition.Stickiness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>

                                <CheckBox Margin="0,12,0,0"
                                          Content="Internalize congestion"
                                          IsChecked="{Binding SelectedTrafficDefinition.InternalizeCongestion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Visibility="{Binding SelectedTrafficDefinition.IsSystemOptimal, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="4"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Style="{StaticResource ValidationTextStyle}"
                                   Text="{Binding SelectedTrafficDefinition.ValidationText}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="6"
                            Padding="12"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="{Binding Terminology.TrafficTypeEditorTip}" />
            <Button DockPanel.Dock="Right"
                    Margin="12,0,0,0"
                    Content="Save Changes"
                    Click="Close_Click"
                    Style="{StaticResource AccessibleEditorButtonStyle}"
                    ToolTip="Click to save changes to the network configuration"
                    AutomationProperties.Name="Save Changes Button"
                    AutomationProperties.HelpText="Saves all modifications made to the network configuration." />
        </DockPanel>
    </Grid>
</Window>
