<UserControl x:Class="MedWNetworkSim.App.InspectorPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TabControl Margin="0,12,0,0">
                <TabItem Header="Summary">
                    <TextBlock Margin="10"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding Summary}"
                               TextWrapping="Wrap" />
                </TabItem>
                <TabItem Header="Flows">
                    <TextBlock Margin="10"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding Summary}"
                               TextWrapping="Wrap" />
                </TabItem>
                <TabItem Header="Capacity">
                    <TextBlock Margin="10"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding Summary}"
                               TextWrapping="Wrap" />
                </TabItem>
                <TabItem Header="Routing">
                    <TextBlock Margin="10"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding Summary}"
                               TextWrapping="Wrap" />
                </TabItem>
                <TabItem Header="Timeline">
                    <TextBlock Margin="10"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding Summary}"
                               TextWrapping="Wrap" />
                </TabItem>
            </TabControl>
        </StackPanel>
    </Border>
</UserControl>
