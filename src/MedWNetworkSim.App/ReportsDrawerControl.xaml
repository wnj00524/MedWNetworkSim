<UserControl x:Class="MedWNetworkSim.App.ReportsDrawerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels">
    <Border Padding="16"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            MaxHeight="360">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Reports" />
                <TextBlock DockPanel.Dock="Right"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Layer-aware tables open on demand." />
            </DockPanel>
            <TabControl Grid.Row="2"
                        MinHeight="250">
                <TabItem Header="{Binding RoutesTabHeader}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding VisibleAllocationHeadline}" />
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding VisibleAllocations}"
                                  SelectedItem="{Binding ReportsDrawer.SelectedReportRow, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Visibility="{Binding RoutesGridVisibility}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Period}" Header="Period" Width="65" />
                                <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="130" />
                                <DataGridTextColumn Binding="{Binding ProducerName}" Header="Producer" Width="150" />
                                <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="150" />
                                <DataGridTextColumn Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Header="Qty" Width="75" />
                                <DataGridTextColumn Binding="{Binding TotalTime, StringFormat={}{0:0.##}}" Header="Time" Width="75" />
                                <DataGridTextColumn Binding="{Binding DeliveredCostPerUnit, StringFormat={}{0:0.##}}" Header="Landed / Unit" Width="110" />
                                <DataGridTemplateColumn Header="Path" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:RouteAllocationRowViewModel}">
                                            <TextBlock Text="{Binding PathDescription}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="2"
                                   Margin="0,24,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding RoutesEmptyText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding RoutesEmptyStateVisibility}" />
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding ConsumerCostsTabHeader}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding VisibleConsumerCostHeadline}" />
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding VisibleConsumerCostSummaries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Visibility="{Binding ConsumerCostsGridVisibility}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="140" />
                                <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="170" />
                                <DataGridTextColumn Binding="{Binding LocalQuantity, StringFormat={}{0:0.##}}" Header="Local Qty" Width="90" />
                                <DataGridTextColumn Binding="{Binding ImportedQuantity, StringFormat={}{0:0.##}}" Header="Imported Qty" Width="100" />
                                <DataGridTextColumn Binding="{Binding BlendedUnitCost, StringFormat={}{0:0.##}}" Header="Blended Unit Cost" Width="130" />
                                <DataGridTextColumn Binding="{Binding TotalMovementCost, StringFormat={}{0:0.##}}" Header="Total Movement Cost" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="2"
                                   Margin="0,24,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding ConsumerCostsEmptyText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding ConsumerCostsEmptyStateVisibility}" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
