<Window x:Class="MedWNetworkSim.App.NodeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Terminology.NodeEditorTitle}"
        Width="1040"
        Height="860"
        MinWidth="920"
        MinHeight="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding Terminology.NodeEditorTitle}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding Terminology.NodeEditorIntro}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding Terminology.NodeDetailsHeader}" />

                    <WrapPanel Grid.Row="2"
                               VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Template" />
                        <ComboBox Width="170"
                                  Margin="0,0,10,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding PlaceTemplateOptions}"
                                  SelectedItem="{Binding SelectedPlaceTemplate, Mode=TwoWay}" />
                        <Button Content="{Binding Terminology.AddNodeButton}" Click="AddNode_Click" />
                        <Button Content="{Binding Terminology.AddNodeFromTemplateButton}" Click="AddNodeFromTemplate_Click" />
                        <TextBlock VerticalAlignment="Center"
                                   Margin="10,0,8,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Demand Preset" />
                        <ComboBox Width="170"
                                  Margin="0,0,10,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding DemographicDemandPresetOptions}"
                                  SelectedItem="{Binding SelectedDemographicDemandPreset, Mode=TwoWay}"
                                  ToolTip="{Binding SelectedDemographicDemandPresetMappingSummary}" />
                        <Button Content="Apply Settings"
                                Click="ApplyDemographicDemandPreset_Click"
                                ToolTip="{Binding SelectedDemographicDemandPresetDescription}" />
                        <Button Content="Remove Selected Node" Click="RemoveNode_Click" />
                    </WrapPanel>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding Terminology.Node}" />
                        <ComboBox Grid.Column="1"
                                  MinWidth="220"
                                  ItemsSource="{Binding Nodes}"
                                  SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                    <TextBlock>
                                        <Run Text="{Binding Name}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding Id}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Id" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,0,0,0"
                                 Text="{Binding SelectedNode.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Name" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Text="{Binding SelectedNode.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Shape" />
                        <ComboBox Grid.Row="6"
                                  Grid.Column="1"
                                  ItemsSource="{Binding SelectedNodeShapeOptions}"
                                  SelectedItem="{Binding SelectedNodeShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="8"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Transhipment Capacity" />
                        <TextBox Grid.Row="8"
                                 Grid.Column="1"
                                 Text="{Binding SelectedNode.TranshipmentCapacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="10" Grid.ColumnSpan="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="X" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedNode.X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Y" />
                                <TextBox Grid.Column="4"
                                         Text="{Binding SelectedNode.Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Node Kind" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SelectedNodeKindOptions}"
                                          SelectedItem="{Binding SelectedNodeKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Child Network" />
                                <ComboBox Grid.Row="2"
                                          Grid.Column="1"
                                          IsEditable="True"
                                          ItemsSource="{Binding SubnetworkIdOptions}"
                                          SelectedItem="{Binding SelectedNode.ReferencedSubnetworkId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Grid.Row="4"
                                            Grid.ColumnSpan="2">
                                    <CheckBox Content="External-facing interface"
                                              IsChecked="{Binding SelectedNode.IsExternalInterface, Mode=TwoWay}" />
                                    <TextBox Margin="0,8,0,0"
                                             ToolTip="Optional interface display name"
                                             Text="{Binding SelectedNode.InterfaceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Expander Grid.Row="12"
                                  Grid.ColumnSpan="2"
                                  Header="Worldbuilder"
                                  IsExpanded="False">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Place Type" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedNode.PlaceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Controlling Actor" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding SelectedNode.ControllingActor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="4"
                                           VerticalAlignment="Top"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Lore" />
                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         MinHeight="76"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding SelectedNode.LoreDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="6"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Tags" />
                                <TextBox Grid.Row="6"
                                         Grid.Column="1"
                                         ToolTip="Comma-separated tags"
                                         Text="{Binding SelectedNode.TagsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                <TextBlock Grid.Row="8"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Template Id" />
                                <TextBox Grid.Row="8"
                                         Grid.Column="1"
                                         IsReadOnly="True"
                                         Text="{Binding SelectedNode.TemplateId, Mode=OneWay}" />
                            </Grid>
                        </Expander>
                    </Grid>

                    <Border Grid.Row="6"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding Terminology.NodeEditorTip}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding Terminology.TrafficRoleEntryHeader}" />

                    <WrapPanel Grid.Row="2">
                        <Button Content="{Binding Terminology.AddTrafficRoleButton}" Click="AddTrafficRole_Click" />
                        <Button Content="{Binding Terminology.ApplyTrafficRoleToAllNodesButton}" Click="ApplyTrafficRoleToAllNodes_Click" />
                        <Button Content="Remove Selected Entry" Click="RemoveTrafficRole_Click" />
                    </WrapPanel>

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Entry" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="260"
                                      ItemsSource="{Binding SelectedNode.TrafficProfiles}"
                                      SelectedItem="{Binding SelectedNodeTrafficProfile, Mode=TwoWay}"
                                      DisplayMemberPath="SelectionLabel" />

                            <TextBlock Grid.Row="2"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding Terminology.TrafficType}" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      ItemsSource="{Binding TrafficTypeNameOptions}"
                                      SelectedItem="{Binding SelectedNodeTrafficType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Role" />
                            <ComboBox Grid.Row="4"
                                      Grid.Column="1"
                                      ItemsSource="{Binding SelectedNodeRoleOptions}"
                                      SelectedItem="{Binding SelectedNodeRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="6"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding Terminology.Producer}" />
                            <TextBox Grid.Row="6"
                                     Grid.Column="1"
                                     IsEnabled="{Binding IsSelectedNodeProducer}"
                                     Text="{Binding SelectedNodeProduction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="8"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding Terminology.Consumer}" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     IsEnabled="{Binding IsSelectedNodeConsumer}"
                                     Text="{Binding SelectedNodeConsumption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="10"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding Terminology.Consumer, StringFormat={}{0} Premium / Unit}" />
                            <TextBox Grid.Row="10"
                                     Grid.Column="1"
                                     IsEnabled="{Binding IsSelectedNodeConsumer}"
                                     Text="{Binding SelectedNodeConsumerPremiumPerUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Grid.Row="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox VerticalAlignment="Center"
                                          Content="{Binding Terminology.Store}"
                                          IsChecked="{Binding IsSelectedNodeStore, Mode=TwoWay}" />
                                <TextBox Grid.Column="1"
                                         Margin="12,0,0,0"
                                         IsEnabled="{Binding IsSelectedNodeStore}"
                                         Text="{Binding SelectedNodeStoreCapacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <GroupBox Grid.Row="14"
                                      Grid.ColumnSpan="2"
                                      Header="Production Windows">
                                <StackPanel Margin="8">
                                    <ItemsControl ItemsSource="{Binding SelectedNodeTrafficProfile.ProductionWindows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            Content="Remove"
                                                            Click="RemoveProductionWindow_Click" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="From" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding StartPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="To" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding EndPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button HorizontalAlignment="Left"
                                            Content="Add production window"
                                            Click="AddProductionWindow_Click" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="16"
                                      Grid.ColumnSpan="2"
                                      Header="Consumption Windows">
                                <StackPanel Margin="8">
                                    <ItemsControl ItemsSource="{Binding SelectedNodeTrafficProfile.ConsumptionWindows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            Content="Remove"
                                                            Click="RemoveConsumptionWindow_Click" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="From" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding StartPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="To" />
                                                    <TextBox Width="70"
                                                             Margin="6,0"
                                                             Text="{Binding EndPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button HorizontalAlignment="Left"
                                            Content="Add consumption window"
                                            Click="AddConsumptionWindow_Click" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="18"
                                      Grid.ColumnSpan="2"
                                      Header="Production Inputs">
                                <StackPanel Margin="8">
                                    <ItemsControl ItemsSource="{Binding SelectedNodeTrafficProfile.InputRequirements}">
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Button DockPanel.Dock="Right"
                Margin="8,0,0,0"
                Padding="6,2"
                Content="Remove"
                Click="RemoveInputRequirement_Click" />
                                                        <ComboBox Width="130"
                  ItemsSource="{Binding DataContext.TrafficTypeNameOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                  SelectedItem="{Binding TrafficType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Width="55"
                 Margin="8,0,4,0"
                 Text="{Binding InputQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Margin="0,0,4,0"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="{DynamicResource MutedForegroundBrush}"
                   Text="->" />
                                                        <TextBox Width="55"
                 Margin="0,0,8,0"
                 Text="{Binding OutputQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="{DynamicResource MutedForegroundBrush}"
                   Text="input:output" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button HorizontalAlignment="Left"
                                            Content="Add input"
                                            Click="AddInputRequirement_Click" />
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="6"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="{Binding SelectedNodeTrafficSelectionLabel}" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding SelectedNodeTrafficRoleSummary}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="{Binding StatusMessage}" />
            <Button DockPanel.Dock="Right"
                    Margin="12,0,0,0"
                    MinWidth="120"
                    MinHeight="44"
                    Content="Save Changes"
                    ToolTip="Click to save changes to the network configuration"
                    AutomationProperties.Name="Save Changes Button"
                    AutomationProperties.HelpText="Saves all modifications made to the network configuration."
                    Click="Close_Click" />
        </DockPanel>
    </Grid>
</Window>
