<UserControl x:Class="MedWNetworkSim.App.LegendPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18">
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentStrongBrush}" Text="Legend" />
            <TextBlock Margin="0,10,0,10" Foreground="{DynamicResource MutedForegroundBrush}" Text="Read the network at a glance: edge thickness shows flow, overlay hue shows pressure, and focus outlines show selected paths." TextWrapping="Wrap" />

            <Border Padding="10" CornerRadius="10" Background="{DynamicResource CardBrush}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Flow pressure" />
                    <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Green = healthy margin, amber = constrained, red = critical." />
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <Border Width="40" Height="8" CornerRadius="4" Background="{DynamicResource SuccessBrush}" />
                        <Border Width="40" Height="8" Margin="6,0,0,0" CornerRadius="4" Background="{DynamicResource WarningBrush}" />
                        <Border Width="40" Height="8" Margin="6,0,0,0" CornerRadius="4" Background="{DynamicResource DangerBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Demand badges" />
            <WrapPanel>
                <Border Margin="0,0,6,6" Padding="7,3" Background="#FFD45B5B" CornerRadius="8"><TextBlock Foreground="White" Text="🧂 Spice" /></Border>
                <Border Margin="0,0,6,6" Padding="7,3" Background="#FF4A8EDC" CornerRadius="8"><TextBlock Foreground="White" Text="💧 Water" /></Border>
                <Border Margin="0,0,6,6" Padding="7,3" Background="#FF5DAA5B" CornerRadius="8"><TextBlock Foreground="White" Text="🌿 Herbs" /></Border>
            </WrapPanel>
            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Nodes with urgent backlog also show a thicker outline and warning summary text." TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
