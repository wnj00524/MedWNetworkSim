<UserControl x:Class="MedWNetworkSim.App.ReportsDrawerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels">
    <UserControl.Resources>
        <Style x:Key="DrawerSegmentedTabItemStyle" TargetType="TabItem">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource CardAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Segment"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Segment" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="Segment" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Segment" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Segment" Property="BorderBrush" Value="{DynamicResource KeyboardFocusBrush}" />
                                <Setter TargetName="Segment" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="20" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}" Foreground="{DynamicResource AccentStrongBrush}" Text="Analysis drawer" />
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource HelperTextStyle}" Text="Understand outcomes first, then inspect rows." />
            </DockPanel>

            <UniformGrid Grid.Row="2" Columns="3">
                <Border Margin="0,0,10,0" Padding="14" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Text="Routes" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding RoutesTabHeader}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding VisibleAllocationHeadline}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,10,0" Padding="14" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Text="Consumer costs" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding ConsumerCostsTabHeader}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding VisibleConsumerCostHeadline}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Padding="14" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Text="Perishing" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding PerishingTabHeader}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding VisiblePerishingHeadline}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TabControl Grid.Row="4" MinHeight="260" ItemContainerStyle="{StaticResource DrawerSegmentedTabItemStyle}">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Routes" />
                            <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding VisibleAllocations.Count}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,12,0,0">
                        <DataGrid ItemsSource="{Binding VisibleAllocations}" SelectedItem="{Binding ReportsDrawer.SelectedReportRow, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" Visibility="{Binding RoutesGridVisibility}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Period}" Header="Period" Width="65" />
                                <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="120" />
                                <DataGridTextColumn Binding="{Binding ProducerName}" Header="Producer" Width="140" />
                                <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="140" />
                                <DataGridTextColumn Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Header="Qty" Width="75" />
                                <DataGridTextColumn Binding="{Binding TotalTime, StringFormat={}{0:0.##}}" Header="Time" Width="75" />
                                <DataGridTextColumn Binding="{Binding DeliveredCostPerUnit, StringFormat={}{0:0.##}}" Header="Cost/Unit" Width="95" />
                                <DataGridTemplateColumn Header="Path" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type vm:RouteAllocationRowViewModel}"><TextBlock Text="{Binding PathDescription}" TextWrapping="Wrap" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Margin="0,24,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding RoutesEmptyText}" TextWrapping="Wrap" Visibility="{Binding RoutesEmptyStateVisibility}" />
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Consumer costs" />
                            <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding VisibleConsumerCostSummaries.Count}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,12,0,0">
                        <DataGrid ItemsSource="{Binding VisibleConsumerCostSummaries}" AutoGenerateColumns="False" IsReadOnly="True" Visibility="{Binding ConsumerCostsGridVisibility}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="140" />
                                <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="170" />
                                <DataGridTextColumn Binding="{Binding LocalQuantity, StringFormat={}{0:0.##}}" Header="Local" Width="90" />
                                <DataGridTextColumn Binding="{Binding ImportedQuantity, StringFormat={}{0:0.##}}" Header="Imported" Width="100" />
                                <DataGridTextColumn Binding="{Binding BlendedUnitCost, StringFormat={}{0:0.##}}" Header="Unit Cost" Width="110" />
                                <DataGridTextColumn Binding="{Binding TotalMovementCost, StringFormat={}{0:0.##}}" Header="Total Movement" Width="140" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Margin="0,24,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding ConsumerCostsEmptyText}" TextWrapping="Wrap" Visibility="{Binding ConsumerCostsEmptyStateVisibility}" />
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Perishing" />
                            <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding VisiblePerishingEvents.Count}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,12,0,0">
                        <DataGrid ItemsSource="{Binding VisiblePerishingEvents}" AutoGenerateColumns="False" IsReadOnly="True" Visibility="{Binding PerishingGridVisibility}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Period}" Header="Period" Width="65" />
                                <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="125" />
                                <DataGridTextColumn Binding="{Binding LocationType}" Header="At" Width="70" />
                                <DataGridTextColumn Binding="{Binding LocationLabel}" Header="Location" Width="180" />
                                <DataGridTextColumn Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Header="Perished" Width="95" />
                                <DataGridTextColumn Binding="{Binding Cause}" Header="Cause" Width="140" />
                                <DataGridTextColumn Binding="{Binding WeightedImpact, StringFormat={}{0:0.##}}" Header="Impact" Width="80" />
                                <DataGridTextColumn Binding="{Binding Detail}" Header="Detail" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Margin="0,24,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding PerishingEmptyText}" TextWrapping="Wrap" Visibility="{Binding PerishingEmptyStateVisibility}" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
