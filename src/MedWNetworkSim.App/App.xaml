<Application x:Class="MedWNetworkSim.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MedWNetworkSim.App">
    <Application.Resources>
        <FontFamily x:Key="AppFontFamily">Segoe UI Semibold</FontFamily>
        <SolidColorBrush x:Key="WindowBrush" Color="#FF060D12" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FF0B141B" />
        <SolidColorBrush x:Key="CanvasBrush" Color="#FF09131C" />
        <SolidColorBrush x:Key="CanvasLineBrush" Color="#332F6E7A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4AB7A8" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#FF6FF5E2" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#264AB7A8" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FF1D3240" />
        <SolidColorBrush x:Key="NodeBrush" Color="#FF11222C" />
        <SolidColorBrush x:Key="NodeBorderBrush" Color="#FF4CC9B5" />
        <SolidColorBrush x:Key="EdgeBrush" Color="#FF8EF6EB" />
        <SolidColorBrush x:Key="EdgeLabelBrush" Color="#FF0F1B24" />
        <SolidColorBrush x:Key="InfoPanelBrush" Color="#FF0F1B24" />
        <SolidColorBrush x:Key="MutedForegroundBrush" Color="#FF8EA4B2" />
        <SolidColorBrush x:Key="StrongForegroundBrush" Color="#FFE4F4F3" />
        <SolidColorBrush x:Key="InputBrush" Color="#FF101C26" />
        <SolidColorBrush x:Key="SectionBrush" Color="#FF0E1A23" />
        <SolidColorBrush x:Key="CardBrush" Color="#FF101E29" />
        <SolidColorBrush x:Key="CardAltBrush" Color="#FF152632" />
        <SolidColorBrush x:Key="TrackBrush" Color="#FF243541" />
        <SolidColorBrush x:Key="NodeWatermarkBrush" Color="#6638C2B2" />
        <SolidColorBrush x:Key="NodeBadgeBrush" Color="#FF132430" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF3FCF81" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFEAAA4F" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FFE06464" />
        <SolidColorBrush x:Key="KeyboardFocusBrush" Color="#FF80F8F5" />
        <SolidColorBrush x:Key="KeyboardFocusFillBrush" Color="#3080F8F5" />

        <Thickness x:Key="CardPadding">14</Thickness>

        <DrawingBrush x:Key="CanvasGridBrush" TileMode="Tile" Viewport="0,0,48,48" ViewportUnits="Absolute" Viewbox="0,0,48,48" ViewboxUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{DynamicResource CanvasBrush}" Geometry="M0,0 H48 V48 H0 Z" />
                    <GeometryDrawing Geometry="M48,0 L0,0 0,48">
                        <GeometryDrawing.Pen>
                            <Pen Brush="{DynamicResource CanvasLineBrush}" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <ControlTemplate x:Key="StrongFocusVisualTemplate">
            <Border Margin="-2" BorderBrush="{DynamicResource KeyboardFocusBrush}" BorderThickness="2" CornerRadius="8" SnapsToDevicePixels="True" />
        </ControlTemplate>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBrush}" />
            <Setter Property="Icon" Value="/Assets/AppIcon.ico" />
        </Style>

        <Style TargetType="Border" x:Key="GlassCardStyle">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="{DynamicResource CardPadding}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FF061317" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle">
                <Setter.Value><Style TargetType="Control"><Setter Property="Template" Value="{StaticResource StrongFocusVisualTemplate}" /></Style></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" CornerRadius="8" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource KeyboardFocusBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{DynamicResource CardAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Tab" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="Tab" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource CardBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource CardAltBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SectionBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource StrongForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Application.Resources>
</Application>
