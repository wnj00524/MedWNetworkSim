<Window x:Class="MedWNetworkSim.App.GraphMlTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Import or Export GraphML"
        Style="{StaticResource DialogChromeWindowStyle}"
        Width="720"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                           Text="Import or export GraphML" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HelperTextStyle}"
                           Text="Import a generic GraphML graph into the simulator or export the current network as GraphML. The defaults below are used only when a GraphML node does not already carry MedW-specific traffic data."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Text="GraphML Files" />

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Padding="12"
                        Background="{DynamicResource InfoPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Style="{StaticResource HelperTextStyle}"
                               Text="Choose a GraphML file to load into the simulator, or choose a destination file to save the current network. You can type a path directly or use Browse."
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Grid.Row="4"
                           VerticalAlignment="Center"
                           Style="{StaticResource FieldLabelTextStyle}"
                           Text="Import File" />
                <Grid Grid.Row="4"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox MinWidth="220"
                             Margin="0,0,12,0"
                             Text="{Binding ImportFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="Browse..."
                            Click="BrowseImportGraphMl_Click" />
                    <Button Grid.Column="2"
                            Content="Import GraphML"
                            Click="ImportGraphMl_Click"
                            IsEnabled="{Binding CanImport}" />
                </Grid>

                <TextBlock Grid.Row="6"
                           VerticalAlignment="Center"
                           Style="{StaticResource FieldLabelTextStyle}"
                           Text="Export File" />
                <Grid Grid.Row="6"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox MinWidth="220"
                             Margin="0,0,12,0"
                             Text="{Binding ExportFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="Browse..."
                            Click="BrowseExportGraphMl_Click"
                            IsEnabled="{Binding CanExport}" />
                    <Button Grid.Column="2"
                            Content="Export GraphML"
                            Click="ExportGraphMl_Click"
                            IsEnabled="{Binding CanSave}" />
                </Grid>

                <TextBlock Grid.Row="8"
                           Grid.ColumnSpan="2"
                           FontSize="11"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding SuggestedExportFileName, StringFormat=Suggested export filename: {0}}"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="10"
                           Grid.ColumnSpan="2"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Default Node Mapping" />

                <TextBlock Grid.Row="12"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Traffic Type" />
                <ComboBox Grid.Row="12"
                          Grid.Column="1"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          ItemsSource="{Binding TrafficTypeOptions}"
                          Text="{Binding DefaultTrafficTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="14"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Role" />
                <ComboBox Grid.Row="14"
                          Grid.Column="1"
                          ItemsSource="{Binding RoleOptions}"
                          SelectedItem="{Binding SelectedRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="16"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Capacity" />
                <TextBox Grid.Row="16"
                         Grid.Column="1"
                         Text="{Binding DefaultCapacityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Border Grid.Row="18"
                        Grid.ColumnSpan="2"
                        Padding="12"
                        Background="{DynamicResource InfoPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentStrongBrush}"
                                   Text="How the defaults are used" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Leave traffic type or role on none when you want imported nodes to stay structural only. When the default role includes transhipment, the capacity becomes that node's shared transhipment limit. Producer or consumer defaults still fall back to 1 unit if they need a starter quantity and no amount is available in the GraphML data."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Import replaces the current network. Save GraphML writes the currently loaded network to the chosen GraphML file." />
            <WrapPanel DockPanel.Dock="Right"
                       Margin="12,0,0,0">
                <Button Content="Close"
                        Click="Close_Click" />
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
