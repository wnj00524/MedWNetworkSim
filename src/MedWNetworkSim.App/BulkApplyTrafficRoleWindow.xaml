<Window x:Class="MedWNetworkSim.App.BulkApplyTrafficRoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bulk Edit Selected Places"
        Style="{StaticResource DialogChromeWindowStyle}"
        Width="820"
        Height="760"
        MinWidth="760"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Style="{StaticResource SectionCardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                           Text="Bulk edit selected places" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HelperTextStyle}"
                           Text="Apply safe shared changes to the current bulk-edit scope. Review the scope and preview before you commit the batch update." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource InsetCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                   Text="Scope" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding ScopeSummary}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource InsetCardBorderStyle}">
                    <StackPanel>
                        <CheckBox Content="Update place type"
                                  FontWeight="SemiBold"
                                  IsChecked="{Binding ApplyPlaceType, Mode=TwoWay}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="Use this for a shared worldbuilding label such as village, market, depot, or port." />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Place type" />
                        <TextBox Margin="0,6,0,0"
                                 IsEnabled="{Binding ApplyPlaceType}"
                                 Text="{Binding PlaceTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource InsetCardBorderStyle}">
                    <StackPanel>
                        <CheckBox Content="Update traffic role and profile"
                                  FontWeight="SemiBold"
                                  IsChecked="{Binding ApplyTrafficRole, Mode=TwoWay}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="Assign, replace, or remove one traffic role for the chosen traffic type across the current scope." />

                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Traffic type" />
                        <ComboBox Margin="0,6,0,0"
                                  IsEditable="True"
                                  IsEnabled="{Binding ApplyTrafficRole}"
                                  IsTextSearchEnabled="False"
                                  ItemsSource="{Binding TrafficTypeOptions}"
                                  Text="{Binding TrafficTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Role" />
                        <ComboBox Margin="0,6,0,0"
                                  IsEnabled="{Binding ApplyTrafficRole}"
                                  ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <UniformGrid Margin="0,12,0,0"
                                     Columns="2">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Production amount" />
                                <TextBox Margin="0,6,0,0"
                                         IsEnabled="{Binding IsProducerRoleSelected}"
                                         Text="{Binding ProductionAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Consumption amount" />
                                <TextBox Margin="0,6,0,0"
                                         IsEnabled="{Binding IsConsumerRoleSelected}"
                                         Text="{Binding ConsumptionAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource InsetCardBorderStyle}">
                    <StackPanel>
                        <CheckBox Content="Update shared transhipment capacity"
                                  FontWeight="SemiBold"
                                  IsChecked="{Binding ApplyTranshipmentCapacity, Mode=TwoWay}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="Leave the value blank to clear the shared capacity from every place in scope." />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Shared transhipment capacity" />
                        <TextBox Margin="0,6,0,0"
                                 IsEnabled="{Binding ApplyTranshipmentCapacity}"
                                 Text="{Binding TranshipmentCapacityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource InfoCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                   Foreground="{DynamicResource AccentStrongBrush}"
                                   Text="Change preview" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding ChangePreview}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource ValidationTextStyle}"
                                   Text="{Binding ValidationText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource HelperTextStyle}"
                       Text="Bulk changes apply immediately to the chosen scope and may affect later simulation results." />
            <WrapPanel DockPanel.Dock="Right"
                       Margin="12,0,0,0">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="Close"
                        Click="Close_Click" />
                <Button Content="Apply bulk edit"
                        Click="Apply_Click"
                        IsEnabled="{Binding CanApply}" />
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
