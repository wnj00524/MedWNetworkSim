<Window x:Class="MedWNetworkSim.App.OsmImportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenStreetMap import options"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="AccessibleFocusStyle" TargetType="Control">
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Focusable" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#2E7D32" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Choose how many OpenStreetMap nodes to keep. Lower percentages import faster and keep the map lighter, while higher percentages preserve more detail." />

        <CheckBox x:Name="EnableRetentionCheckBox"
                  Grid.Row="1"
                  Content="Reduce imported node count"
                  IsChecked="False"
                  Style="{StaticResource AccessibleFocusStyle}"
                  Checked="EnableRetentionCheckBox_OnChanged"
                  Unchecked="EnableRetentionCheckBox_OnChanged" />

        <StackPanel Grid.Row="2" Margin="20,8,0,0">
            <TextBlock Text="Retain target (%)" />
            <DockPanel LastChildFill="False" Margin="0,4,0,0">
                <Slider x:Name="RetentionSlider"
                        Width="330"
                        Minimum="1"
                        Maximum="100"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="25"
                        ValueChanged="RetentionValueChanged"
                        Style="{StaticResource AccessibleFocusStyle}" />
                <TextBox x:Name="RetentionTextBox"
                         Width="64"
                         Margin="8,0,0,0"
                         VerticalContentAlignment="Center"
                         Text="25"
                         TextChanged="RetentionTextBoxOnTextChanged"
                         Style="{StaticResource AccessibleFocusStyle}" />
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="20,8,0,0">
            <TextBlock Text="Retention strategy" />
            <ComboBox x:Name="StrategyComboBox"
                      Margin="0,4,0,0"
                      SelectedIndex="0"
                      Style="{StaticResource AccessibleFocusStyle}">
                <ComboBoxItem Content="Balanced (recommended)" Tag="Balanced" />
                <ComboBoxItem Content="Preserve road shape" Tag="PreserveShape" />
                <ComboBoxItem Content="Preserve major junctions" Tag="PreserveJunctionImportance" />
            </ComboBox>
        </StackPanel>

        <CheckBox x:Name="AlwaysKeepNamedTransitionsCheckBox"
                  Grid.Row="4"
                  Margin="20,8,0,0"
                  IsChecked="True"
                  Content="Always keep points where road names change"
                  Style="{StaticResource AccessibleFocusStyle}" />

        <CheckBox x:Name="PreserveShapeOnLongSegmentsCheckBox"
                  Grid.Row="5"
                  Margin="20,4,0,0"
                  IsChecked="True"
                  Content="Preserve shape anchors on long roads"
                  Style="{StaticResource AccessibleFocusStyle}" />

        <TextBlock x:Name="EstimatedCountText"
                   Grid.Row="6"
                   Margin="20,10,0,0"
                   TextWrapping="Wrap"
                   Text="Estimated retained node count: approximately 25% of parsed OSM road nodes (final exact count shown after parsing)." />

        <TextBlock Grid.Row="7"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   Foreground="#555"
                   Text="Tip: if your requested percentage is too low for safe connectivity and shape, the importer will automatically raise it to a safe minimum and report both values." />

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button MinWidth="90" Margin="0,0,8,0" Content="Cancel" Click="CancelClick" />
            <Button MinWidth="90" Content="Import" IsDefault="True" Click="ImportClick" />
        </StackPanel>
    </Grid>
</Window>
