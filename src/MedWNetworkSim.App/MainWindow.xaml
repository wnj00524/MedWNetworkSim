<Window x:Class="MedWNetworkSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1600"
        Height="980"
        MinWidth="1280"
        MinHeight="840">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="300" />
        </Grid.RowDefinitions>

        <Border Padding="22"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,24,0">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentStrongBrush}"
                               Text="MedW Network Simulator" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource StrongForegroundBrush}"
                               Text="{Binding NetworkName}" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{StaticResource MutedForegroundBrush}"
                               Text="{Binding NetworkDescription}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedForegroundBrush}"
                               Text="{Binding ActiveFileLabel}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Button Content="Load Sample" Click="LoadSample_Click" />
                    <Button Content="Open JSON..." Click="OpenFile_Click" />
                    <Button Content="Auto Arrange"
                            Click="AutoArrange_Click"
                            IsEnabled="{Binding HasNetwork}" />
                    <Button Content="Save JSON..."
                            Click="SaveFile_Click"
                            IsEnabled="{Binding HasNetwork}" />
                    <Button Content="Run Simulation"
                            Click="RunSimulation_Click"
                            IsEnabled="{Binding HasNetwork}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Padding="18"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Network Overview" />

                        <UniformGrid Grid.Row="2" Columns="3">
                            <Border Margin="0,0,8,0"
                                    Padding="12"
                                    Background="#FFF7EEE2"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource MutedForegroundBrush}"
                                               Text="Nodes" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Text="{Binding NodeCount}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,8,0"
                                    Padding="12"
                                    Background="#FFF7EEE2"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource MutedForegroundBrush}"
                                               Text="Edges" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Text="{Binding EdgeCount}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="12"
                                    Background="#FFF7EEE2"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource MutedForegroundBrush}"
                                               Text="Traffic Types" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Text="{Binding TrafficTypeCount}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Traffic Types" />

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding TrafficTypes}"
                                 SelectedItem="{Binding SelectedTraffic, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TrafficSummaryViewModel}">
                                    <Border x:Name="TrafficCard"
                                            Padding="14"
                                            Background="#FFFFFBF4"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="6" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <DockPanel>
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <Border DockPanel.Dock="Right"
                                                        Padding="10,4"
                                                        Background="#FFF2E3D2"
                                                        CornerRadius="12">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding RoutingPreferenceLabel}" />
                                                </Border>
                                            </DockPanel>

                                            <TextBlock Grid.Row="2"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedForegroundBrush}"
                                                       Text="{Binding SupplyDemandSummary}"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Grid.Row="4"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentStrongBrush}"
                                                       Text="{Binding OutcomeSummary}"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Grid.Row="6"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedForegroundBrush}"
                                                       Text="{Binding NotesSummary}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                     Value="True">
                                            <Setter TargetName="TrafficCard" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter TargetName="TrafficCard" Property="Background" Value="#FFFDF1E6" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Padding="18"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <StackPanel>
                        <TextBlock FontSize="17"
                                   FontWeight="SemiBold"
                                   Text="How To Use It" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedForegroundBrush}"
                                   Text="Load a JSON network, drag nodes directly on the canvas, then run the simulation. Select a traffic type in the list to filter the routed movements table below."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Network Canvas" />
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedForegroundBrush}"
                                   Text="Drag node cards to reposition them" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <Grid Width="{Binding WorkspaceWidth}" Height="{Binding WorkspaceHeight}">
                            <Border Background="{StaticResource CanvasGridBrush}"
                                    BorderBrush="#33B18A63"
                                    BorderThickness="1"
                                    CornerRadius="20" />

                            <ItemsControl ItemsSource="{Binding Edges}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <Canvas Width="{Binding DataContext.WorkspaceWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Height="{Binding DataContext.WorkspaceHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{StaticResource EdgeBrush}"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{StaticResource EdgeBrush}"
                                                     Visibility="{Binding ArrowVisibility}" />

                                            <Border Canvas.Left="{Binding LabelLeft}"
                                                    Canvas.Top="{Binding LabelTop}"
                                                    Width="176"
                                                    Height="58"
                                                    Padding="10,6"
                                                    Background="{StaticResource EdgeLabelBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <StackPanel>
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentStrongBrush}"
                                                               Text="{Binding DirectionLabel}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource StrongForegroundBrush}"
                                                               Text="{Binding SummaryLabel}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource MutedForegroundBrush}"
                                                               Text="{Binding CapacityLabel}" />
                                                </StackPanel>
                                            </Border>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding Nodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                        <Thumb Width="{Binding Width}"
                                               Height="{Binding Height}"
                                               Cursor="SizeAll"
                                               DragDelta="NodeThumb_OnDragDelta"
                                               ToolTip="{Binding FullTrafficSummary}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Padding="12"
                                                            Background="{StaticResource NodeBrush}"
                                                            BorderBrush="{StaticResource NodeBorderBrush}"
                                                            BorderThickness="1.4"
                                                            CornerRadius="20">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="*" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel>
                                                                <TextBlock FontSize="15"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Name}" />
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{StaticResource MutedForegroundBrush}"
                                                                           Text="{Binding Id}" />
                                                            </StackPanel>

                                                            <Border Grid.Row="1"
                                                                    Margin="0,8,0,8"
                                                                    Padding="10,3"
                                                                    HorizontalAlignment="Left"
                                                                    Background="#FFF0E6D6"
                                                                    CornerRadius="12">
                                                                <TextBlock FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding TrafficProfileCountLabel}" />
                                                            </Border>

                                                            <ScrollViewer Grid.Row="2"
                                                                          VerticalScrollBarVisibility="Auto"
                                                                          HorizontalScrollBarVisibility="Disabled">
                                                                <ItemsControl ItemsSource="{Binding TrafficProfiles}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type vm:NodeTrafficProfileViewModel}">
                                                                            <Grid Margin="0,0,0,4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock FontSize="11"
                                                                                           FontWeight="SemiBold"
                                                                                           Text="{Binding TrafficType}" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           FontSize="11"
                                                                                           Foreground="{StaticResource MutedForegroundBrush}"
                                                                                           Text="{Binding RoleSummary}" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Simulation Outputs" />
                    <TextBlock DockPanel.Dock="Right"
                               FontSize="12"
                               Foreground="{StaticResource MutedForegroundBrush}"
                               Text="Select a traffic type to filter both tabs" />
                </DockPanel>

                <TabControl Grid.Row="2">
                    <TabItem Header="Consumer Costs">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       Text="{Binding VisibleConsumerCostHeadline}" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding VisibleConsumerCostSummaries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="140" />
                                    <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="170" />
                                    <DataGridTextColumn Binding="{Binding LocalQuantity, StringFormat={}{0:0.##}}" Header="Local Qty" Width="90" />
                                    <DataGridTextColumn Binding="{Binding LocalUnitCost, StringFormat={}{0:0.##}}" Header="Local Unit Cost" Width="110" />
                                    <DataGridTextColumn Binding="{Binding ImportedQuantity, StringFormat={}{0:0.##}}" Header="Imported Qty" Width="100" />
                                    <DataGridTextColumn Binding="{Binding ImportedUnitCost, StringFormat={}{0:0.##}}" Header="Imported Unit Cost" Width="125" />
                                    <DataGridTextColumn Binding="{Binding BlendedUnitCost, StringFormat={}{0:0.##}}" Header="Blended Unit Cost" Width="125" />
                                    <DataGridTextColumn Binding="{Binding TotalMovementCost, StringFormat={}{0:0.##}}" Header="Total Movement Cost" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Routed Movements">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       Text="{Binding VisibleAllocationHeadline}" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding VisibleAllocations}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="120" />
                                    <DataGridTextColumn Binding="{Binding RoutingPreferenceLabel}" Header="Preference" Width="95" />
                                    <DataGridTextColumn Binding="{Binding SourceLabel}" Header="Source" Width="85" />
                                    <DataGridTextColumn Binding="{Binding ProducerName}" Header="Producer" Width="135" />
                                    <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="135" />
                                    <DataGridTextColumn Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Header="Qty" Width="65" />
                                    <DataGridTextColumn Binding="{Binding TotalTime, StringFormat={}{0:0.##}}" Header="Time" Width="70" />
                                    <DataGridTextColumn Binding="{Binding TransitCostPerUnit, StringFormat={}{0:0.##}}" Header="Transit / Unit" Width="95" />
                                    <DataGridTextColumn Binding="{Binding BidCostPerUnit, StringFormat={}{0:0.##}}" Header="Bid / Unit" Width="80" />
                                    <DataGridTextColumn Binding="{Binding DeliveredCostPerUnit, StringFormat={}{0:0.##}}" Header="Landed / Unit" Width="95" />
                                    <DataGridTextColumn Binding="{Binding TotalMovementCost, StringFormat={}{0:0.##}}" Header="Total Cost" Width="90" />
                                    <DataGridTemplateColumn Header="Path" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:RouteAllocationRowViewModel}">
                                                <TextBlock Text="{Binding PathDescription}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>

                <TextBlock Grid.Row="4"
                           FontSize="13"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
