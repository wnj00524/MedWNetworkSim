<Window x:Class="MedWNetworkSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        xmlns:local="clr-namespace:MedWNetworkSim.App"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding WindowTitle}"
        Width="1680"
        Height="1040"
        MinWidth="1380"
        MinHeight="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
        <Window.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Window.Resources>
        <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="TopControlsRegion"
                Padding="16"
                Focusable="True"
                KeyboardNavigation.TabNavigation="Continue">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReportsWorkspaceActive}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogTitleTextStyle}" Foreground="{DynamicResource AccentStrongBrush}" Text="Network workspace" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource HelperTextStyle}" Text="{Binding ActiveWorldLabel}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Foreground="{DynamicResource AccentStrongBrush}" Text="Workspace mode" />
                        <ComboBox Width="190" Margin="0,8,0,0" ItemsSource="{Binding WorkspaceModes}" SelectedItem="{Binding SelectedWorkspaceMode, Mode=TwoWay}" />
                        <WrapPanel Margin="0,10,0,0">
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource FieldLabelTextStyle}" Text="Theme" />
                            <ComboBox Width="150" Margin="8,0,0,0" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InsetCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="File and import" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Text="Start a network, open saved work, or move data in and out." />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="New network" Click="NewNetwork_Click" />
                                <Button Content="Open network..." Click="OpenFile_Click" />
                                <Button Content="Save network..." Click="QuickSave_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Import GraphML..." Click="GraphMl_Click" />
                                <Button Content="Export GraphML..." Click="GraphMl_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Import OSM..." Click="ImportOsm_Click" />
                            </WrapPanel>
                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource InfoCardBorderStyle}"
                                    Visibility="{Binding IsImportingOsm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Foreground="{DynamicResource AccentStrongBrush}"
                                               Text="OSM import in progress" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="{Binding OsmImportStatus}" />
                                    <ProgressBar Margin="0,8,0,0"
                                                 Height="14"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 IsIndeterminate="{Binding IsOsmImportProgressIndeterminate}"
                                                 Value="{Binding OsmImportProgress}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource InsetCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Canvas and edit" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Text="Create places, edit routes, and open advanced configuration." />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="{Binding Terminology.AddNodeButton}" Click="AddNode_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Edit edges..." Click="EditEdges_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Traffic types..." Click="EditTrafficTypes_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Network properties..." Click="NetworkProperties_Click" IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource InsetCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Inspector and panels" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Text="Keep selection details, filters, and keyboard guidance close at hand." />
                            <WrapPanel Margin="0,10,0,0">
                                <ToggleButton Content="Layers" Click="ToggleLayers_Click" IsChecked="{Binding IsLayersPanelOpen, Mode=OneWay}" IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Inspector" Click="ToggleInspector_Click" IsChecked="{Binding InspectorPanel.IsOpen, Mode=OneWay}" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Keyboard help" Click="ShowKeyboardHelp_Click" />
                            </WrapPanel>
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding WorkspaceModeCallout}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource InsetCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Reports and simulation" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Text="Run the network, step the timeline, inspect outcomes, and export reports." />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Run simulation" Click="RunSimulation_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Next period" Click="NextTimelinePeriod_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Reset timeline" Click="ResetTimeline_Click" IsEnabled="{Binding HasNetwork}" />
                                <ToggleButton Content="Reports drawer" Click="ToggleReportsDrawer_Click" IsChecked="{Binding ReportsDrawer.IsOpen, Mode=OneWay}" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Export current report..." Click="ExportCurrentReportShell_Click" IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Export timeline report..." Click="ExportTimelineReportShell_Click" IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding DataContext.RightRailSpacerColumnWidth, ElementName=RootWindow}" />
                <ColumnDefinition Width="{Binding DataContext.RightRailColumnWidth, ElementName=RootWindow}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="20"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                           Foreground="{DynamicResource AccentStrongBrush}"
                                           Text="Canvas status" />
                                <TextBlock Margin="0,3,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding StatusMessage}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center">
                                <Border Margin="8,0,0,0"
                                        Padding="8"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EmphasizeSimulationControls}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                                                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Text="{Binding RunControlLabel}" />
                                        <Button Content="Run simulation"
                                                Click="RunSimulation_Click"
                                                IsEnabled="{Binding HasNetwork}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Text="{Binding TimelineControlLabel}" />
                                        <Button Content="Next period"
                                                Click="NextTimelinePeriod_Click"
                                                IsEnabled="{Binding HasNetwork}" />
                                        <Button Content="Reset timeline"
                                                Click="ResetTimeline_Click"
                                                IsEnabled="{Binding HasNetwork}" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Padding="10,8"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentStrongBrush}"
                                           Text="Canvas guidance" />
                                <TextBlock Margin="0,2,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding GraphKeyboardHint}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Padding="10,6"
                                    FontSize="11"
                                    Content="Keyboard help"
                                    Click="ShowKeyboardHelp_Click" />
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="NetworkCanvasScrollViewer"
                                  Grid.Row="4"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False"
                                  PreviewMouseDown="NetworkCanvasScrollViewer_OnPreviewMouseDown"
                                  PreviewMouseMove="NetworkCanvasScrollViewer_OnPreviewMouseMove"
                                  PreviewMouseUp="NetworkCanvasScrollViewer_OnPreviewMouseUp"
                                  LostMouseCapture="NetworkCanvasScrollViewer_OnLostMouseCapture">
                        <Grid x:Name="NetworkCanvasGrid"
                              Width="{Binding WorkspaceWidth}"
                              Height="{Binding WorkspaceHeight}"
                              Focusable="True"
                              KeyboardNavigation.TabNavigation="None"
                              AutomationProperties.Name="Network graph canvas workspace"
                              AutomationProperties.HelpText="Canvas workspace. Arrow keys move node focus, Enter edits, N adds a place, E starts a route, and Shift+F10 opens actions."
                              GotKeyboardFocus="NetworkCanvasGrid_OnGotKeyboardFocus"
                              PreviewKeyDown="NetworkCanvasGrid_OnPreviewKeyDown"
                              PreviewMouseLeftButtonDown="NetworkCanvasGrid_OnPreviewMouseLeftButtonDown"
                              PreviewMouseRightButtonDown="NetworkCanvasGrid_OnPreviewMouseRightButtonDown"
                              PreviewMouseWheel="NetworkCanvasGrid_OnPreviewMouseWheel">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="NetworkCanvasScaleTransform"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Grid.LayoutTransform>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.Terminology.AddNodeButton, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Click="CanvasAddNode_Click" />
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <Border Background="{DynamicResource CanvasGridBrush}"
                                    BorderBrush="{DynamicResource CanvasLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20" />

                            <Canvas>
                                <Canvas.RenderTransform>
                                    <TranslateTransform X="{Binding WorkspaceTranslateX}"
                                                        Y="{Binding WorkspaceTranslateY}" />
                                </Canvas.RenderTransform>

                                <Line x:Name="EdgeCreationPreviewLine"
                                      IsHitTestVisible="False"
                                      Stroke="{DynamicResource AccentStrongBrush}"
                                      StrokeThickness="3"
                                      StrokeDashArray="6,4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />

                                <ItemsControl ItemsSource="{Binding Edges}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                            <Canvas Width="{Binding DataContext.WorkspaceWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Height="{Binding DataContext.WorkspaceHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{DynamicResource EdgeBrush}"
                                                  StrokeThickness="2.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.72"
                                                  MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                  ToolTip="{Binding EdgeToolTipText}"
                                                  Visibility="{Binding EdgeVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="Transparent"
                                                  StrokeThickness="18"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                  ToolTip="{Binding EdgeToolTipText}"
                                                  Visibility="{Binding EdgeVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{Binding FlowStrokeBrush}"
                                                  StrokeThickness="{Binding FlowStrokeThickness}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.92"
                                                  MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                  ToolTip="{Binding EdgeToolTipText}"
                                                  Visibility="{Binding FlowOverlayVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{DynamicResource AccentStrongBrush}"
                                                  StrokeThickness="{Binding RouteHighlightStrokeThickness}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.78"
                                                  Visibility="{Binding RouteHighlightVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{DynamicResource KeyboardFocusBrush}"
                                                  StrokeThickness="7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.88"
                                                  Visibility="Collapsed">
                                                <Line.Style>
                                                    <Style TargetType="Line">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsKeyboardFocused}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Line.Style>
                                            </Line>

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{DynamicResource EdgeBrush}"
                                                     Visibility="{Binding ArrowVisibility}" />

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{Binding FlowStrokeBrush}"
                                                     Opacity="0.92"
                                                     Visibility="{Binding FlowArrowVisibility}" />

                                            <Border Canvas.Left="{Binding LabelLeft}"
                                                    Canvas.Top="{Binding LabelTop}"
                                                    Width="{Binding LabelWidth}"
                                                    Height="{Binding LabelHeight}"
                                                    Padding="8,4"
                                                    Background="{DynamicResource EdgeLabelBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Opacity="0.9"
                                                    MouseLeftButtonDown="EdgeVisual_OnMouseLeftButtonDown"
                                                    ToolTip="{Binding EdgeToolTipText}"
                                                    Visibility="{Binding EdgeVisibility}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsKeyboardFocused}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource KeyboardFocusBrush}" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentStrongBrush}"
                                                               Text="{Binding RouteSummaryLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="{Binding RouteDetailLabel}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding TechnicalLabelVisibility}" />
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding FlowStrokeBrush}"
                                                               Text="{Binding FlowSummaryLabel}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding FlowSummaryVisibility}" />
                                                </StackPanel>
                                            </Border>
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Nodes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                            <Thumb Width="{Binding Width}"
                                                   Height="{Binding Height}"
                                                   Cursor="SizeAll"
                                                   Focusable="True"
                                                   IsTabStop="False"
                                                   AutomationProperties.Name="{Binding Name, StringFormat=Place {0}}"
                                                   AutomationProperties.HelpText="Enter edits this place, Space selects it, E starts a route, Ctrl+Arrow moves it, and Shift+F10 opens actions."
                                                   ToolTipService.ShowsToolTipOnKeyboardFocus="True"
                                                   GotKeyboardFocus="NodeThumb_OnGotKeyboardFocus"
                                                   PreviewKeyDown="NodeThumb_OnPreviewKeyDown"
                                                   PreviewMouseLeftButtonDown="NodeThumb_OnPreviewMouseLeftButtonDown"
                                                   PreviewMouseLeftButtonUp="NodeThumb_OnPreviewMouseLeftButtonUp"
                                                   DragDelta="NodeThumb_OnDragDelta"
                                                   ToolTip="{Binding FullTrafficSummary}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid>
                                                        <Border x:Name="NodeKeyboardFocusBorder"
                                                                Margin="-4"
                                                                BorderBrush="{DynamicResource KeyboardFocusBrush}"
                                                                BorderThickness="3"
                                                                CornerRadius="12"
                                                                Opacity="0" />
                                                        <Border Padding="12"
                                                                Background="{DynamicResource NodeBrush}"
                                                                BorderBrush="{Binding NodeBorderDisplayBrush}"
                                                                BorderThickness="1.4"
                                                                CornerRadius="{Binding NodeCornerRadius}"
                                                                Visibility="{Binding SquareNodeVisibility}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderThickness" Value="1.4" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasUrgentBacklog}" Value="True">
                                                                            <Setter Property="BorderThickness" Value="3.2" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <Ellipse Fill="{DynamicResource NodeBrush}"
                                                                 Stroke="{Binding NodeBorderDisplayBrush}"
                                                                 StrokeThickness="1.4"
                                                                 Visibility="{Binding CircularNodeVisibility}" />
                                                        <Viewbox Visibility="{Binding OutlineShapeVisibility}"
                                                                 IsHitTestVisible="False">
                                                            <Path Data="{Binding ShapeIconGeometry}"
                                                                  Fill="{DynamicResource NodeBrush}"
                                                                  Stroke="{Binding NodeBorderDisplayBrush}"
                                                                  StrokeThickness="1.4"
                                                                  Stretch="Uniform" />
                                                        </Viewbox>
                                                        <Grid Margin="12,10">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Row="1"
                                                                       Margin="0,2,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                                       Text="{Binding PlaceTypeLabel}"
                                                                       TextTrimming="CharacterEllipsis" />

                                                            <ItemsControl Grid.Row="2"
                                                                          Margin="0,8,0,0"
                                                                          Visibility="{Binding HasCanvasRoleLines, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                          ItemsSource="{Binding CanvasRoleLines}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Margin="0,0,0,2"
                                                                                   FontSize="9.5"
                                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                                   Text="{Binding Text}"
                                                                                   TextWrapping="Wrap"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   MaxHeight="26">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="FontWeight" Value="Normal" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsEmphasized}" Value="True">
                                                                                            <Setter Property="FontWeight" Value="Bold" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <ItemsControl Grid.Row="2"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Top"
                                                                          Visibility="{Binding DemandBadgeVisibility}"
                                                                          ToolTip="{Binding DemandTooltipText}"
                                                                          ToolTipService.ShowsToolTipOnKeyboardFocus="True"
                                                                          ItemsSource="{Binding DemandBadges}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="3,0,0,3"
                                                                                Padding="4,1"
                                                                                Background="{Binding AccentBrush}"
                                                                                CornerRadius="8"
                                                                                AutomationProperties.Name="{Binding AutomationLabel}">
                                                                            <TextBlock FontSize="10"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="White"
                                                                                       Text="{Binding Icon}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <StackPanel Grid.Row="3"
                                                                        Margin="0,4,0,0">
                                                                <TextBlock FontSize="9.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource AccentStrongBrush}"
                                                                           Text="{Binding CanvasUnmetNeedLine}"
                                                                           TextWrapping="Wrap"
                                                                           Visibility="{Binding HasCanvasUnmetNeedLine, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           FontSize="9.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource AccentStrongBrush}"
                                                                           Text="{Binding CanvasPressureLine}"
                                                                           TextWrapping="Wrap"
                                                                           Visibility="{Binding HasCanvasPressureLine, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="4"
                                                                        Margin="0,6,0,0"
                                                                        Visibility="{Binding DemandMeterVisibility}"
                                                                        ToolTip="{Binding DemandTooltipText}"
                                                                        ToolTipService.ShowsToolTipOnKeyboardFocus="True"
                                                                        AutomationProperties.Name="{Binding DemandMeterSummary}">
                                                                <Border Width="{Binding DemandMeterTrackWidthValue}"
                                                                        Height="6"
                                                                        Background="{DynamicResource CardAltBrush}"
                                                                        CornerRadius="3">
                                                                    <Border Width="{Binding DemandMeterFillWidth}"
                                                                            HorizontalAlignment="Left"
                                                                            Background="{DynamicResource AccentStrongBrush}"
                                                                            CornerRadius="3" />
                                                                </Border>
                                                                <TextBlock Margin="0,2,0,0"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                                           Text="{Binding DemandMeterSummary}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter TargetName="NodeKeyboardFocusBorder"
                                                                    Property="BorderBrush"
                                                                    Value="{DynamicResource AccentStrongBrush}" />
                                                            <Setter TargetName="NodeKeyboardFocusBorder"
                                                                    Property="BorderThickness"
                                                                    Value="2.4" />
                                                            <Setter TargetName="NodeKeyboardFocusBorder"
                                                                    Property="Opacity"
                                                                    Value="0.95" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsKeyboardFocused}" Value="True">
                                                            <Setter TargetName="NodeKeyboardFocusBorder"
                                                                    Property="BorderBrush"
                                                                    Value="{DynamicResource KeyboardFocusBrush}" />
                                                            <Setter TargetName="NodeKeyboardFocusBorder"
                                                                    Property="BorderThickness"
                                                                    Value="3" />
                                                            <Setter TargetName="NodeKeyboardFocusBorder"
                                                                    Property="Opacity"
                                                                    Value="1" />
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                            </Thumb>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer x:Name="RightRailRegion"
                          Grid.Column="2"
                          Focusable="True"
                          IsTabStop="True"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding DataContext.RightRailVisibility, ElementName=RootWindow}">
                <StackPanel>
                    <local:LayersPanelControl DataContext="{Binding LayersPanel}"
                                              Visibility="{Binding LayersPanelVisibility}" />
                    <local:InspectorPanelControl Margin="0,14,0,0"
                                                 DataContext="{Binding}"
                                                 Visibility="{Binding InspectorPanel.Visibility}" />
                    <local:LegendPanelControl Margin="0,14,0,0"
                                              Visibility="{Binding LegendPanelVisibility}" />
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <GridSplitter Grid.Row="2"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{DynamicResource BorderBrush}"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Visibility="{Binding DataContext.BottomWorkspaceVisibility, ElementName=RootWindow}" />

        <Border x:Name="BottomReportsRegion"
                Grid.Row="3"
                Padding="18"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Focusable="True"
                MinHeight="{Binding ReportsDrawerMinHeight}"
                MaxHeight="{Binding ReportsDrawerMaxHeight}"
                Visibility="{Binding DataContext.BottomWorkspaceVisibility, ElementName=RootWindow}">
            <local:ReportsDrawerControl />
        </Border>
    </Grid>
</Window>
