<Window x:Class="MedWNetworkSim.App.BulkApplyTrafficRoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Apply Traffic Role To All Nodes"
        Width="720"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Apply Traffic Role To All Nodes" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Stamp the same traffic role onto every node in the current network. You can create or update one traffic-role entry per node in a single step."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="16"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Bulk Role Details" />

                <TextBlock Grid.Row="2"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Traffic Type" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          ItemsSource="{Binding TrafficTypeOptions}"
                          Text="{Binding TrafficTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Role" />
                <ComboBox Grid.Row="4"
                          Grid.Column="1"
                          ItemsSource="{Binding RoleOptions}"
                          SelectedItem="{Binding SelectedRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="6"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Production Amount" />
                <TextBox Grid.Row="6"
                         Grid.Column="1"
                         IsEnabled="{Binding IsProducerRoleSelected}"
                         Text="{Binding ProductionAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="8"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Consumption Amount" />
                <TextBox Grid.Row="8"
                         Grid.Column="1"
                         IsEnabled="{Binding IsConsumerRoleSelected}"
                         Text="{Binding ConsumptionAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="10"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Transhipment Capacity" />
                <StackPanel Grid.Row="10"
                            Grid.Column="1">
                    <CheckBox Content="Set shared transhipment capacity on every node"
                              IsChecked="{Binding ApplyTranshipmentCapacity, Mode=TwoWay}"
                              IsEnabled="{Binding IsTransshipRoleSelected}" />
                    <TextBox Margin="0,10,0,0"
                             IsEnabled="{Binding CanEditTranshipmentCapacity}"
                             Text="{Binding TranshipmentCapacityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{StaticResource MutedForegroundBrush}"
                               Text="Leave the capacity box blank to clear any existing shared transhipment limit when the checkbox is enabled."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="12"
                        Grid.ColumnSpan="2"
                        Padding="12"
                        Background="{StaticResource InfoPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Text="What happens when you apply" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedForegroundBrush}"
                                   Text="{Binding ApplySummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="14"
                           Grid.ColumnSpan="2"
                           FontSize="11"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Traffic type is required. Producer and consumer roles need positive amounts. Shared transhipment capacity is only updated when the checkbox above is enabled."
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource MutedForegroundBrush}"
                       Text="This updates every node in the currently loaded network." />
            <WrapPanel DockPanel.Dock="Right"
                       Margin="12,0,0,0">
                <Button Content="Apply To All Nodes"
                        Click="Apply_Click"
                        IsEnabled="{Binding CanApply}" />
                <Button Content="Close"
                        Click="Close_Click" />
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
