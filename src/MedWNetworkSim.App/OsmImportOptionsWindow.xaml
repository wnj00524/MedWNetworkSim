<Window x:Class="MedWNetworkSim.App.OsmImportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import OSM"
        Style="{StaticResource DialogChromeWindowStyle}"
        Width="520"
        Height="620"
        MinHeight="580"
        MinWidth="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Style="{StaticResource SectionCardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                           Text="Import OSM" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HelperTextStyle}"
                           Text="Choose how much road detail to keep before the importer turns the OSM map into a network. Lower retention imports faster; higher retention keeps more shape detail." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource InsetCardBorderStyle}">
                    <StackPanel>
                        <CheckBox x:Name="EnableRetentionCheckBox"
                                  Content="Reduce imported node count"
                                  IsChecked="False"
                                  Checked="EnableRetentionCheckBox_OnChanged"
                                  Unchecked="EnableRetentionCheckBox_OnChanged" />

                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Retain target (%)" />
                        <DockPanel LastChildFill="False" Margin="0,6,0,0">
                            <Slider x:Name="RetentionSlider"
                                    Width="330"
                                    Minimum="1"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="25"
                                    ValueChanged="RetentionValueChanged" />
                            <TextBox x:Name="RetentionTextBox"
                                     Width="64"
                                     Margin="8,0,0,0"
                                     VerticalContentAlignment="Center"
                                     Text="25"
                                     TextChanged="RetentionTextBoxOnTextChanged" />
                        </DockPanel>

                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Retention strategy" />
                        <ComboBox x:Name="StrategyComboBox"
                                  Margin="0,6,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Balanced (recommended)" Tag="Balanced" />
                            <ComboBoxItem Content="Preserve road shape" Tag="PreserveShape" />
                            <ComboBoxItem Content="Preserve major junctions" Tag="PreserveJunctionImportance" />
                        </ComboBox>

                        <CheckBox x:Name="AlwaysKeepNamedTransitionsCheckBox"
                                  Margin="0,12,0,0"
                                  IsChecked="True"
                                  Content="Always keep points where road names change" />

                        <CheckBox x:Name="PreserveShapeOnLongSegmentsCheckBox"
                                  Margin="0,8,0,0"
                                  IsChecked="True"
                                  Content="Preserve shape anchors on long roads" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource InfoCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                   Foreground="{DynamicResource AccentStrongBrush}"
                                   Text="Import preview" />
                        <TextBlock x:Name="EstimatedCountText"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="Estimated retained node count: approximately 25% of parsed OSM road nodes (final exact count shown after parsing)." />
                        <TextBlock x:Name="ImportSummaryText"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="Review the settings above, then start the import." />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="If the target is too low to keep the road graph connected, the importer will raise it to a safe minimum and report the result." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,0">
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="110"
                    Margin="0,0,8,0"
                    Content="Cancel"
                    Click="CancelClick" />
            <Button MinWidth="140"
                    Content="Start import"
                    IsDefault="True"
                    Click="ImportClick" />
        </StackPanel>
    </Grid>
</Window>
