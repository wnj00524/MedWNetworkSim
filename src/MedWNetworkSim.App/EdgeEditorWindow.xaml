<Window x:Class="MedWNetworkSim.App.EdgeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Terminology.EdgeEditorTitle}"
        Width="1100"
        Height="760"
        MinWidth="940"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="AccessibleEditorButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="KeyboardNavigation.IsTabStop" Value="True" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding Terminology.EdgeEditorTitle}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding Terminology.EdgeEditorIntro}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding Terminology.Edges}" />

                    <WrapPanel Grid.Row="2">
                        <Button Content="{Binding Terminology.AddEdgeButton}"
                                Click="AddEdge_Click"
                                Style="{StaticResource AccessibleEditorButtonStyle}"
                                ToolTip="Add a new edge to the network"
                                AutomationProperties.Name="Add Edge Button"
                                AutomationProperties.HelpText="Creates a new edge row that you can edit." />
                        <Button Content="Remove Selected Edge"
                                Click="RemoveEdge_Click"
                                Style="{StaticResource AccessibleEditorButtonStyle}"
                                ToolTip="Remove the currently selected edge"
                                AutomationProperties.Name="Remove Selected Edge Button"
                                AutomationProperties.HelpText="Deletes the selected edge from the network." />
                    </WrapPanel>

                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding Edges}"
                              SelectedItem="{Binding SelectedEdge, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              MinHeight="360"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Id" Width="86" />
                            <DataGridTemplateColumn Header="From" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding FromNodeId}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <ComboBox ItemsSource="{Binding DataContext.NodeIdOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding FromNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="To" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding ToNodeId}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <ComboBox ItemsSource="{Binding DataContext.NodeIdOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding ToNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Header="Time" Width="80" />
                            <DataGridTextColumn Binding="{Binding Cost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Header="Cost" Width="80" />
                            <DataGridTextColumn Binding="{Binding Capacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Header="Capacity" Width="90" />
                            <DataGridTextColumn Binding="{Binding FromInterfaceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="From Interface" Width="120" />
                            <DataGridTextColumn Binding="{Binding ToInterfaceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="To Interface" Width="120" />
                            <DataGridCheckBoxColumn Binding="{Binding IsBidirectional, Mode=TwoWay}" Header="2-way" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Node Properties"
                               AutomationProperties.Name="Node Properties Label"
                               AutomationProperties.HelpText="Displays properties and settings for the selected edge." />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding Terminology.Edge}" />
                        <ComboBox Grid.Column="1"
                                  MinWidth="230"
                                  ItemsSource="{Binding Edges}"
                                  SelectedItem="{Binding SelectedEdge, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                    <TextBlock>
                                        <Run Text="{Binding Id}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding FromNodeId}" />
                                        <Run Text=" -> " />
                                        <Run Text="{Binding ToNodeId}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Id" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Text="{Binding SelectedEdge.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="From" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  ItemsSource="{Binding NodeIdOptions}"
                                  SelectedItem="{Binding SelectedEdge.FromNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="To" />
                        <ComboBox Grid.Row="6"
                                  Grid.Column="1"
                                  ItemsSource="{Binding NodeIdOptions}"
                                  SelectedItem="{Binding SelectedEdge.ToNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="8"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Time" />
                        <TextBox Grid.Row="8"
                                 Grid.Column="1"
                                 Text="{Binding SelectedEdge.Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="10"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Cost" />
                        <TextBox Grid.Row="10"
                                 Grid.Column="1"
                                 Text="{Binding SelectedEdge.Cost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="12" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Capacity" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedEdge.Capacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Grid.Column="3"
                                      VerticalAlignment="Center"
                                      Content="Bidirectional"
                                      IsChecked="{Binding SelectedEdge.IsBidirectional, Mode=TwoWay}" />
                        </Grid>

                        <StackPanel Grid.Row="14"
                                    Grid.ColumnSpan="2">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="From Interface" />
                                <ComboBox Grid.Column="1"
                                          IsEditable="True"
                                          ItemsSource="{Binding FromInterfaceNodeOptions}"
                                          SelectedItem="{Binding SelectedEdge.FromInterfaceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="To Interface" />
                                <ComboBox Grid.Row="2"
                                          Grid.Column="1"
                                          IsEditable="True"
                                          ItemsSource="{Binding ToInterfaceNodeOptions}"
                                          SelectedItem="{Binding SelectedEdge.ToInterfaceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                        <Expander Header="Worldbuilder"
                                  IsExpanded="False">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Route Type" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedEdge.RouteType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Top"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Access Notes" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         MinHeight="56"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding SelectedEdge.AccessNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="4"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Seasonal Risk" />
                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         Text="{Binding SelectedEdge.SeasonalRisk, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="6"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Toll Notes" />
                                <TextBox Grid.Row="6"
                                         Grid.Column="1"
                                         Text="{Binding SelectedEdge.TollNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="8"
                                           VerticalAlignment="Top"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Security Notes" />
                                <TextBox Grid.Row="8"
                                         Grid.Column="1"
                                         MinHeight="56"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding SelectedEdge.SecurityNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                        </StackPanel>
                    </Grid>

                    <GroupBox Grid.Row="4"
                              Header="Edge Settings"
                              Padding="12"
                              AutomationProperties.Name="Edge Settings Group"
                              AutomationProperties.HelpText="Contains controls for editing edge traffic permissions.">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Text="Edge Traffic Permissions"
                                       ToolTip="Set permissions for each traffic type on the selected edge"
                                       AutomationProperties.Name="Edge Traffic Permissions Label"
                                       AutomationProperties.HelpText="Set permissions for each traffic type on the selected edge." />
                            <TextBlock Grid.Row="2"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Use network default keeps the shared rule. Override default lets this edge use its own permitted, blocked, or limited setting."
                                       TextWrapping="Wrap" />
                        </Grid>
                    </GroupBox>

                    <DataGrid Grid.Row="6"
                              TabIndex="2"
                              ToolTip="Edge traffic permission control"
                              AutomationProperties.Name="Edge Traffic Permission Control"
                              AutomationProperties.HelpText="Select which traffic types are permitted on this edge"
                              ItemsSource="{Binding SelectedEdge.TrafficPermissions}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              MinHeight="220"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic type" IsReadOnly="True" Width="*" />
                            <DataGridTemplateColumn Header="Default" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding OverrideChoiceText}"
                                                  IsChecked="{Binding IsOverrideActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="State" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SelectedModeLabel}"
                                                   Visibility="{Binding OverrideEditorsVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding PermissionModes}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Visibility="{Binding OverrideEditorsVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Limit type" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SelectedLimitKindLabel}"
                                                   Visibility="{Binding LimitEditorsVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding LimitKinds}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding LimitKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Visibility="{Binding LimitEditorsVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Limit" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LimitValueText}"
                                                   Visibility="{Binding LimitEditorsVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding LimitValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding LimitEditorsVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding EffectiveSummary}" Header="Effective" IsReadOnly="True" Width="220" />
                            <DataGridTemplateColumn Header="Validation" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="#B42318"
                                                   Text="{Binding ValidationMessage, StringFormat=⚠ {0}}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding ValidationVisibility}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="8"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding Terminology.EdgeCapacityTip}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="10"
                            Padding="12"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="{Binding Terminology.EdgeEditorTip}" />
            <Button DockPanel.Dock="Right"
                    Margin="12,0,0,0"
                    Content="Save Changes"
                    Click="Close_Click"
                    Style="{StaticResource AccessibleEditorButtonStyle}"
                    ToolTip="Click to save changes to the network configuration"
                    AutomationProperties.Name="Save Changes Button"
                    AutomationProperties.HelpText="Saves all modifications made to the network configuration."
                    TabIndex="0" />
        </DockPanel>
    </Grid>
</Window>
