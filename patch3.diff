+            AgentRiskTolerance = ParseDoubleOption(named, "risk-tolerance"),
+            HasAgentRiskTolerance = HasOption(named, "risk-tolerance"),
+            AgentCooperationWeight = ParseDoubleOption(named, "cooperation-weight"),
