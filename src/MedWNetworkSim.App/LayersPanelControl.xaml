<UserControl x:Class="MedWNetworkSim.App.LayersPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels">
    <Border Padding="16" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18">
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentStrongBrush}" Text="Visualization controls" />
            <TextBlock Margin="0,6,0,12" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}" Text="Tune what is rendered, then spotlight one or more traffic layers." TextWrapping="Wrap" />

            <Border Padding="10" Background="{DynamicResource CardBrush}" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}" Text="Layer mode" />
                    <ComboBox Margin="0,6,0,0" ItemsSource="{Binding DisplayModes}" SelectedItem="{Binding SelectedDisplayMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Margin="0,10,0,0" Content="Keep aggregate context visible" IsChecked="{Binding ShowCombinedTraffic, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <TextBlock Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedForegroundBrush}" Text="Traffic layers" />
            <ItemsControl ItemsSource="{Binding TrafficLayers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LayerVisibilityState}">
                        <Border Margin="0,0,0,8" Padding="10,8" Background="{DynamicResource CardAltBrush}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding TrafficType}" />
                                <CheckBox Grid.Column="1" Margin="8,0,0,0" Content="Show" IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                <CheckBox Grid.Column="2" Margin="8,0,0,0" Content="Spotlight" IsChecked="{Binding IsHighlighted, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,10,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedForegroundBrush}" Text="Overlays" />
            <WrapPanel>
                <CheckBox Margin="0,0,14,6" Content="Congestion" IsChecked="{Binding ShowCongestionOverlay, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Labels" IsChecked="{Binding ShowLabels, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Edge capacity" IsChecked="{Binding ShowEdgeCapacities, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Node capacity" IsChecked="{Binding ShowNodeCapacities, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Stores" IsChecked="{Binding ShowStoresInventoryMarkers, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Transhipment" IsChecked="{Binding ShowTranshipmentHubs, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Routes" IsChecked="{Binding ShowRouteHighlights, Mode=TwoWay}" />
                <CheckBox Margin="0,0,14,6" Content="Temporal" IsChecked="{Binding ShowTemporalInFlightOverlays, Mode=TwoWay}" />
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
