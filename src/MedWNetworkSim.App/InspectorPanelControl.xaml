<UserControl x:Class="MedWNetworkSim.App.InspectorPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border Padding="16"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                           Foreground="{DynamicResource AccentStrongBrush}"
                           Text="Inspector" />
                <TextBlock Margin="0,4,0,0"
                           Style="{StaticResource HelperTextStyle}"
                           Text="Edit the current selection here, then open the full editor when you need more detail." />
            </StackPanel>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource InsetCardBorderStyle}"
                            Visibility="{Binding InspectorShowsNetworkProperties, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                       Text="Network properties" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="No place or route is selected, so the inspector is showing network-wide settings." />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Network name" />
                            <TextBox Text="{Binding NetworkName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Description" />
                            <TextBox MinHeight="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding NetworkDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Default allocation mode" />
                            <ComboBox DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      ItemsSource="{Binding AllocationModeOptions}"
                                      SelectedValue="{Binding DefaultAllocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="More network settings..."
                                        Click="OpenNetworkProperties_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Traffic types..."
                                        Click="OpenTrafficTypes_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0"
                            Style="{StaticResource InsetCardBorderStyle}"
                            Visibility="{Binding InspectorShowsSelectedNode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                       Text="Selected place" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding SelectedNode.WorldbuilderSummary}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Name" />
                            <TextBox Text="{Binding SelectedNode.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Place type" />
                            <TextBox Text="{Binding SelectedNode.PlaceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Shape" />
                            <ComboBox ItemsSource="{Binding SelectedNodeShapeOptions}"
                                      SelectedItem="{Binding SelectedNodeShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Shared transhipment capacity" />
                            <TextBox Text="{Binding SelectedNode.TranshipmentCapacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource ValidationTextStyle}"
                                       Text="{Binding SelectedNodeValidationText}" />

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource InfoCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Foreground="{DynamicResource AccentStrongBrush}"
                                               Text="Traffic summary" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="{Binding SelectedNodeTrafficRoleSummary}" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Open node editor..."
                                        Click="OpenNodeEditor_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Advanced traffic settings..."
                                        Click="OpenNodeEditor_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0"
                            Style="{StaticResource InsetCardBorderStyle}"
                            Visibility="{Binding InspectorShowsSelectedEdge, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                       Text="Selected route" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding SelectedEdge.EdgeToolTipText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Travel time" />
                            <TextBox Text="{Binding SelectedEdge.Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Travel cost" />
                            <TextBox Text="{Binding SelectedEdge.Cost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Capacity" />
                            <TextBox Text="{Binding SelectedEdge.Capacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Route type" />
                            <TextBox Text="{Binding SelectedEdge.RouteType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource ValidationTextStyle}"
                                       Text="{Binding SelectedEdgeValidationText}" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Open edge editor..."
                                        Click="OpenEdgeEditor_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0"
                            Style="{StaticResource InsetCardBorderStyle}"
                            Visibility="{Binding InspectorShowsBulkSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                       Text="Selected places" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding BulkSelectionSummary}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Shared place type" />
                            <TextBox Text="{Binding BulkSelectedPlaceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Shared transhipment capacity" />
                            <TextBox Text="{Binding BulkSelectedTranshipmentCapacityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource ValidationTextStyle}"
                                       Text="{Binding BulkSelectionValidationText}" />

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource InfoCardBorderStyle}">
                                <TextBlock Style="{StaticResource HelperTextStyle}"
                                           Text="Use shared fields here for safe quick edits, or open the full batch workflow for traffic roles and broader bulk changes." />
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Bulk edit selected items..."
                                        Click="OpenBulkEdit_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Traffic types..."
                                        Click="OpenTrafficTypes_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0"
                            Style="{StaticResource InsetCardBorderStyle}"
                            Visibility="{Binding InspectorShowsFallbackSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}"
                                       Text="{Binding InspectorPanel.Title}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding InspectorPanel.SummaryText}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding InspectorPanel.FlowsText}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding InspectorPanel.CapacityText}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding InspectorPanel.RoutingText}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="{Binding InspectorPanel.TimelineText}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
