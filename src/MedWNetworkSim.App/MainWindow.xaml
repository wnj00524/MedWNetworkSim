<Window x:Class="MedWNetworkSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedWNetworkSim.App.ViewModels"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding WindowTitle}"
        Width="1680"
        Height="1040"
        MinWidth="1380"
        MinHeight="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,24,0">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentStrongBrush}"
                               Text="MedW Network Simulator" />
                    <Border Margin="0,10,0,0"
                            Padding="10,8"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <CheckBox Content="Loop timeline periods"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Foreground="{DynamicResource AccentStrongBrush}"
                                      IsChecked="{Binding IsTimelineLoopEnabled, Mode=TwoWay}" />
                            <WrapPanel Margin="0,8,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Loop after period" />
                                <TextBox Width="80"
                                         Margin="10,0,0,0"
                                         HorizontalAlignment="Left"
                                         IsEnabled="{Binding IsTimelineLoopEnabled}"
                                         Background="{DynamicResource InputBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Text="{Binding TimelineLoopLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="then restart at period 1" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           ItemWidth="Auto"
                           Margin="0,-4,0,0">
                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Network" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="New Network" Click="NewNetwork_Click" />
                                <Button Content="Load Sample" Click="LoadSample_Click" />
                                <Button Content="Open JSON..." Click="OpenFile_Click" />
                                <Button Content="Save JSON..."
                                        Click="SaveFile_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="GraphML..." Click="GraphMl_Click" />
                                <Button Content="Reports..."
                                        Click="Reports_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Editors" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Traffic Types..." Click="EditTrafficTypes_Click" />
                                <Button Content="Edges..." Click="EditEdges_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Workspace" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="{Binding CanvasOnlyButtonLabel}"
                                        Click="ToggleCanvasOnly_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Auto Arrange"
                                        Click="AutoArrange_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,10,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Simulation" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Run Simulation"
                                        Click="RunSimulation_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Reset Timeline"
                                        Click="ResetTimeline_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                                <Button Content="Next Period"
                                        Click="NextTimelinePeriod_Click"
                                        IsEnabled="{Binding HasNetwork}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,4,0,0"
                            Padding="12"
                            Background="{DynamicResource SectionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Appearance" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Theme" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding DataContext.RightRailSpacerColumnWidth, ElementName=RootWindow}" />
                <ColumnDefinition Width="{Binding DataContext.RightRailColumnWidth, ElementName=RootWindow}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="20"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Network Canvas" />
                        <TextBlock DockPanel.Dock="Right"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentStrongBrush}"
                                   Text="{Binding TimelineHeadline}" />
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Primary workspace: drag node cards to reposition them. Canvas flow visuals follow the selected traffic filter after a simulation run." />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <Grid x:Name="NetworkCanvasGrid"
                              Width="{Binding WorkspaceWidth}"
                              Height="{Binding WorkspaceHeight}"
                              PreviewMouseLeftButtonDown="NetworkCanvasGrid_OnPreviewMouseLeftButtonDown"
                              PreviewMouseRightButtonDown="NetworkCanvasGrid_OnPreviewMouseRightButtonDown">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add Node"
                                              Click="CanvasAddNode_Click" />
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <Border Background="{DynamicResource CanvasGridBrush}"
                                    BorderBrush="{DynamicResource CanvasLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20" />

                            <Line x:Name="EdgeCreationPreviewLine"
                                  IsHitTestVisible="False"
                                  Stroke="{DynamicResource AccentStrongBrush}"
                                  StrokeThickness="3"
                                  StrokeDashArray="6,4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />

                            <ItemsControl ItemsSource="{Binding Edges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                        <Canvas Width="{Binding DataContext.WorkspaceWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Height="{Binding DataContext.WorkspaceHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{DynamicResource EdgeBrush}"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Visibility="{Binding EdgeVisibility}" />

                                            <Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{Binding FlowStrokeBrush}"
                                                  StrokeThickness="{Binding FlowStrokeThickness}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Opacity="0.92"
                                                  Visibility="{Binding FlowOverlayVisibility}" />

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{DynamicResource EdgeBrush}"
                                                     Visibility="{Binding ArrowVisibility}" />

                                            <Polygon Points="{Binding ArrowPoints}"
                                                     Fill="{Binding FlowStrokeBrush}"
                                                     Opacity="0.92"
                                                     Visibility="{Binding FlowArrowVisibility}" />

                                            <Border Canvas.Left="{Binding LabelLeft}"
                                                    Canvas.Top="{Binding LabelTop}"
                                                    Width="{Binding LabelWidth}"
                                                    Height="{Binding LabelHeight}"
                                                    Padding="10,6"
                                                    Background="{DynamicResource EdgeLabelBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Visibility="{Binding EdgeVisibility}">
                                                <StackPanel>
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentStrongBrush}"
                                                               Text="{Binding DirectionLabel}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource StrongForegroundBrush}"
                                                               Text="{Binding SummaryLabel}" />
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding FlowStrokeBrush}"
                                                               Text="{Binding FlowSummaryLabel}"
                                                               Visibility="{Binding FlowSummaryVisibility}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Text="{Binding CapacityDisplayLabel}" />
                                                    <Grid Margin="0,4,0,0"
                                                          Visibility="{Binding UtilizationBarVisibility}">
                                                        <Border Height="6"
                                                                Background="{DynamicResource TrackBrush}"
                                                                CornerRadius="3" />
                                                        <Border Width="{Binding UtilizationBarWidth}"
                                                                Height="6"
                                                                HorizontalAlignment="Left"
                                                                Background="{Binding FlowStrokeBrush}"
                                                                CornerRadius="3" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding Nodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                        <Thumb Width="{Binding Width}"
                                               Height="{Binding Height}"
                                               Cursor="SizeAll"
                                               PreviewMouseLeftButtonDown="NodeThumb_OnPreviewMouseLeftButtonDown"
                                               PreviewMouseLeftButtonUp="NodeThumb_OnPreviewMouseLeftButtonUp"
                                               DragDelta="NodeThumb_OnDragDelta"
                                               ToolTip="{Binding FullTrafficSummary}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid>
                                                        <Border Padding="12"
                                                                Background="{DynamicResource NodeBrush}"
                                                                BorderBrush="{Binding NodeBorderDisplayBrush}"
                                                                BorderThickness="1.4"
                                                                CornerRadius="{Binding NodeCornerRadius}"
                                                                Visibility="{Binding SquareNodeVisibility}" />
                                                        <Ellipse Fill="{DynamicResource NodeBrush}"
                                                                 Stroke="{Binding NodeBorderDisplayBrush}"
                                                                 StrokeThickness="1.4"
                                                                 Visibility="{Binding CircularNodeVisibility}" />
                                                        <Viewbox Visibility="{Binding OutlineShapeVisibility}"
                                                                 IsHitTestVisible="False">
                                                            <Path Data="{Binding ShapeIconGeometry}"
                                                                  Fill="{DynamicResource NodeBrush}"
                                                                  Stroke="{Binding NodeBorderDisplayBrush}"
                                                                  StrokeThickness="1.4"
                                                                  Stretch="Uniform" />
                                                        </Viewbox>
                                                        <Viewbox Width="56"
                                                                 Height="56"
                                                                 Margin="0,10,10,0"
                                                                 HorizontalAlignment="Right"
                                                                 VerticalAlignment="Top"
                                                                 Opacity="0.22"
                                                                 IsHitTestVisible="False"
                                                                 Visibility="{Binding ShapeWatermarkVisibility}">
                                                            <Path Data="{Binding ShapeIconGeometry}"
                                                                  Fill="{DynamicResource NodeWatermarkBrush}"
                                                                  Stretch="Uniform" />
                                                        </Viewbox>
                                                        <Grid Margin="12">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="*" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <StackPanel DockPanel.Dock="Left">
                                                                        <TextBlock FontSize="15"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding Name}" />
                                                                        <TextBlock FontSize="11"
                                                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                                                   Text="{Binding Id}" />
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </StackPanel>

                                                            <DockPanel Grid.Row="1"
                                                                       Margin="0,8,0,8">
                                                                <Border Padding="10,3"
                                                                        HorizontalAlignment="Left"
                                                                        Background="{DynamicResource CardAltBrush}"
                                                                        CornerRadius="12">
                                                                    <TextBlock FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding TrafficProfileCountLabel}" />
                                                                </Border>

                                                                <TextBlock DockPanel.Dock="Right"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                                           Text="{Binding TranshipmentCapacityLabel}" />
                                                            </DockPanel>

                                                            <Border Grid.Row="2"
                                                                    Margin="0,0,0,8"
                                                                    Padding="8"
                                                                    Background="{DynamicResource CardBrush}"
                                                                    BorderBrush="{Binding SimulationBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="12"
                                                                    Visibility="{Binding SimulationPanelVisibility}">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{Binding SimulationBrush}"
                                                                               Text="{Binding FlowSummaryLabel}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                                               Text="{Binding TranshipmentUsageLabel}"
                                                                               TextWrapping="Wrap"
                                                                               Visibility="{Binding TranshipmentUsageVisibility}" />
                                                                    <Grid Margin="0,4,0,0"
                                                                          Visibility="{Binding TranshipmentUsageBarVisibility}">
                                                                        <Border Height="6"
                                                                                Background="{DynamicResource TrackBrush}"
                                                                                CornerRadius="3" />
                                                                        <Border Width="{Binding TranshipmentUtilizationBarWidth}"
                                                                                Height="6"
                                                                                HorizontalAlignment="Left"
                                                                                Background="{Binding SimulationBrush}"
                                                                                CornerRadius="3" />
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>

                                                            <Border Grid.Row="2"
                                                                    Margin="0,0,0,8"
                                                                    Padding="8"
                                                                    Background="{DynamicResource CardAltBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="12"
                                                                    VerticalAlignment="Bottom"
                                                                    Visibility="{Binding TimelinePanelVisibility}">
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource AccentStrongBrush}"
                                                                           Text="{Binding TimelineSummaryLabel}"
                                                                           TextWrapping="Wrap" />
                                                            </Border>

                                                            <ScrollViewer Grid.Row="3"
                                                                          VerticalScrollBarVisibility="Auto"
                                                                          HorizontalScrollBarVisibility="Disabled">
                                                                <ItemsControl ItemsSource="{Binding TrafficProfiles}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type vm:NodeTrafficProfileViewModel}">
                                                                            <Grid Margin="0,0,0,4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock FontSize="11"
                                                                                           FontWeight="SemiBold"
                                                                                           Text="{Binding TrafficType}" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           FontSize="11"
                                                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                                                           Text="{Binding RoleSummary}" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding DataContext.RightRailVisibility, ElementName=RootWindow}">
                <StackPanel>
                    <Border Padding="18"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Network Overview" />
                            </Expander.Header>

                            <UniformGrid Margin="0,18,0,0" Columns="3">
                                <Border Margin="0,0,8,0"
                                        Padding="12"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Text="Nodes" />
                                        <TextBlock FontSize="24"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding NodeCount}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,8,0"
                                        Padding="12"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Text="Edges" />
                                        <TextBlock FontSize="24"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding EdgeCount}" />
                                    </StackPanel>
                                </Border>

                                <Border Padding="12"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Text="Traffic Types" />
                                        <TextBlock FontSize="24"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding TrafficTypeCount}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Expander>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Padding="18"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Traffic Types" />
                            </Expander.Header>

                            <ListBox Margin="0,12,0,0"
                                     MinHeight="180"
                                     MaxHeight="420"
                                     ItemsSource="{Binding TrafficTypes}"
                                     SelectedItem="{Binding SelectedTraffic, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:TrafficSummaryViewModel}">
                                        <Border x:Name="TrafficCard"
                                                Padding="14"
                                                Background="{DynamicResource CardBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <DockPanel>
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <Border DockPanel.Dock="Right"
                                                            Padding="10,4"
                                                            Background="{DynamicResource CardAltBrush}"
                                                            CornerRadius="12">
                                                        <TextBlock FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding RoutingPreferenceLabel}" />
                                                    </Border>
                                                </DockPanel>

                                                <TextBlock Grid.Row="2"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           Text="{Binding SupplyDemandSummary}"
                                                           TextWrapping="Wrap" />

                                                <TextBlock Grid.Row="4"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentStrongBrush}"
                                                           Text="{Binding OutcomeSummary}"
                                                           TextWrapping="Wrap" />

                                                <TextBlock Grid.Row="6"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           Text="{Binding NotesSummary}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                         Value="True">
                                                <Setter TargetName="TrafficCard" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="TrafficCard" Property="Background" Value="{DynamicResource CardBrush}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Padding="18"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <TextBlock FontSize="17"
                                           FontWeight="SemiBold"
                                           Text="How To Use It" />
                            </Expander.Header>

                            <TextBlock Margin="0,10,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Create a new network or load an existing JSON file. Use the Network Editor tab to add traffic types, nodes, node traffic profiles, and edges directly in the app, then drag nodes on the canvas and run the simulation."
                                       TextWrapping="Wrap" />
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <Border Grid.Row="2"
                Padding="18"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                MaxHeight="360"
                Visibility="{Binding DataContext.BottomWorkspaceVisibility, ElementName=RootWindow}">
            <Expander IsExpanded="True">
                <Expander.Header>
                    <DockPanel LastChildFill="False">
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Simulation And Editing" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Select a traffic type to filter simulation outputs, or collapse this section while arranging the network."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentStrongBrush}"
                                   Text="Canvas Focus Mode" />
                    </DockPanel>
                </Expander.Header>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="0"
                                MinHeight="280">
                    <TabItem Header="Consumer Costs">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding VisibleConsumerCostHeadline}" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding VisibleConsumerCostSummaries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="140" />
                                    <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="170" />
                                    <DataGridTextColumn Binding="{Binding LocalQuantity, StringFormat={}{0:0.##}}" Header="Local Qty" Width="90" />
                                    <DataGridTextColumn Binding="{Binding LocalUnitCost, StringFormat={}{0:0.##}}" Header="Local Unit Cost" Width="110" />
                                    <DataGridTextColumn Binding="{Binding ImportedQuantity, StringFormat={}{0:0.##}}" Header="Imported Qty" Width="100" />
                                    <DataGridTextColumn Binding="{Binding ImportedUnitCost, StringFormat={}{0:0.##}}" Header="Imported Unit Cost" Width="125" />
                                    <DataGridTextColumn Binding="{Binding BlendedUnitCost, StringFormat={}{0:0.##}}" Header="Blended Unit Cost" Width="125" />
                                    <DataGridTextColumn Binding="{Binding TotalMovementCost, StringFormat={}{0:0.##}}" Header="Total Movement Cost" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Routed Movements">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding VisibleAllocationHeadline}" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding VisibleAllocations}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Period}" Header="Period" Width="65" />
                                    <DataGridTextColumn Binding="{Binding TrafficType}" Header="Traffic" Width="120" />
                                    <DataGridTextColumn Binding="{Binding RoutingPreferenceLabel}" Header="Preference" Width="95" />
                                    <DataGridTextColumn Binding="{Binding AllocationModeLabel}" Header="Allocation" Width="165" />
                                    <DataGridTextColumn Binding="{Binding SourceLabel}" Header="Source" Width="85" />
                                    <DataGridTextColumn Binding="{Binding ProducerName}" Header="Producer" Width="135" />
                                    <DataGridTextColumn Binding="{Binding ConsumerName}" Header="Consumer" Width="135" />
                                    <DataGridTextColumn Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Header="Qty" Width="65" />
                                    <DataGridTextColumn Binding="{Binding TotalTime, StringFormat={}{0:0.##}}" Header="Time" Width="70" />
                                    <DataGridTextColumn Binding="{Binding TransitCostPerUnit, StringFormat={}{0:0.##}}" Header="Transit / Unit" Width="95" />
                                    <DataGridTextColumn Binding="{Binding BidCostPerUnit, StringFormat={}{0:0.##}}" Header="Bid / Unit" Width="80" />
                                    <DataGridTextColumn Binding="{Binding DeliveredCostPerUnit, StringFormat={}{0:0.##}}" Header="Landed / Unit" Width="95" />
                                    <DataGridTextColumn Binding="{Binding TotalMovementCost, StringFormat={}{0:0.##}}" Header="Total Cost" Width="90" />
                                    <DataGridTemplateColumn Header="Path" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:RouteAllocationRowViewModel}">
                                                <TextBlock Text="{Binding PathDescription}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Node Roles">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Choose the node and traffic-role entry from dropdown lists here, then open the dedicated node editor window to make changes."
                                       TextWrapping="Wrap" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="280" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="280" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="Node" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Nodes}"
                                          SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                            <TextBlock>
                                                <Run Text="{Binding Name}" />
                                                <Run Text=" (" />
                                                <Run Text="{Binding Id}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="Traffic Role" />
                                <ComboBox Grid.Column="4"
                                          ItemsSource="{Binding SelectedNode.TrafficProfiles}"
                                          SelectedItem="{Binding SelectedNodeTrafficProfile, Mode=TwoWay}"
                                          DisplayMemberPath="SelectionLabel" />
                            </Grid>

                            <Border Grid.Row="4"
                                    Padding="14"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Use The Node Editor Window" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Text="The dedicated node editor provides dropdowns for node, traffic role, traffic type, and role, and keeps the amount fields together in a single place."
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button Content="Open Node Editor..." Click="EditSelectedNode_Click" />
                                        <Button Content="Apply Role To All Nodes..." Click="ApplyTrafficRoleToAllNodes_Click" />
                                        <Button Content="Add Traffic Role" Click="AddTrafficProfile_Click" />
                                        <Button Content="Remove Selected" Click="RemoveTrafficProfile_Click" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentStrongBrush}"
                                               Text="{Binding SelectedNodeTrafficProfile.SelectionLabel}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Text="{Binding SelectedNodeTrafficProfile.RoleSummary}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Network Editor">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Create a network, maintain traffic types, edit nodes and their traffic roles, and edit edges directly in the app." />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.25*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.15*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="12"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Traffic Types" />

                                        <WrapPanel Grid.Row="2">
                                            <Button Content="Add Traffic Type" Click="AddTrafficType_Click" />
                                            <Button Content="Open Traffic Type Editor..." Click="EditTrafficTypes_Click" />
                                            <Button Content="Remove Selected" Click="RemoveTrafficType_Click" />
                                        </WrapPanel>

                                        <TextBlock Grid.Row="4"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Text="Traffic type definitions control route choice, branch splitting behavior, and shared capacity bidding defaults for both edges and node transhipment." />

                                        <DataGrid Grid.Row="6"
                                                  MinHeight="150"
                                                  ItemsSource="{Binding TrafficDefinitions}"
                                                  SelectedItem="{Binding SelectedTrafficDefinition, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="False"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Name, Mode=TwoWay}" Header="Name" Width="95" />
                                                <DataGridTemplateColumn Header="Preference" Width="118">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TrafficTypeDefinitionEditorViewModel}">
                                                            <TextBlock Text="{Binding RoutingPreference}" VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TrafficTypeDefinitionEditorViewModel}">
                                                            <ComboBox Padding="2"
                                                                      MinWidth="96"
                                                                      ItemsSource="{Binding DataContext.RoutingPreferences, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding RoutingPreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Allocation" Width="180">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TrafficTypeDefinitionEditorViewModel}">
                                                            <TextBlock Text="{Binding AllocationModeLabel}" VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TrafficTypeDefinitionEditorViewModel}">
                                                            <ComboBox Padding="2"
                                                                      MinWidth="160"
                                                                      DisplayMemberPath="Label"
                                                                      SelectedValuePath="Value"
                                                                      ItemsSource="{Binding DataContext.AllocationModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedValue="{Binding AllocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Binding="{Binding CapacityBidPerUnit, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="Bid / Unit" Width="90" />
                                                <DataGridTextColumn Binding="{Binding Description, Mode=TwoWay}" Header="Description" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="12"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="125" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Nodes" />

                                        <WrapPanel Grid.Row="2">
                                            <Button Content="Add Node" Click="AddNode_Click" />
                                            <Button Content="Edit Selected Node..." Click="EditSelectedNode_Click" />
                                            <Button Content="Apply Role To All Nodes..." Click="ApplyTrafficRoleToAllNodes_Click" />
                                            <Button Content="Remove Selected" Click="RemoveNode_Click" />
                                        </WrapPanel>

                                        <DataGrid Grid.Row="4"
                                                  ItemsSource="{Binding Nodes}"
                                                  SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Id, Mode=TwoWay}" Header="Id" Width="85" />
                                                <DataGridTextColumn Binding="{Binding Name, Mode=TwoWay}" Header="Name" Width="*" />
                                                <DataGridTemplateColumn Header="Shape" Width="96">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding Shape}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                                            <ComboBox ItemsSource="{Binding ShapeOptions}"
                                                                      SelectedItem="{Binding Shape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Binding="{Binding X, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="X" Width="60" />
                                                <DataGridTextColumn Binding="{Binding Y, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="Y" Width="60" />
                                                <DataGridTextColumn Binding="{Binding TranshipmentCapacity, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="Tranship Cap" Width="92" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Grid.Row="6"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Node Role Editing" />

                                        <WrapPanel Grid.Row="8">
                                            <Button Content="Open Node Editor..." Click="EditSelectedNode_Click" />
                                        </WrapPanel>

                                        <Border Grid.Row="10"
                                                Padding="12"
                                                Background="{DynamicResource InfoPanelBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           Text="Use the dedicated node editor window to choose nodes, set optional shared transhipment capacity, manage traffic-role entries from dropdown lists, or stamp one traffic role across every node in a single step."
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,10,0,0"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentStrongBrush}"
                                                           Text="{Binding SelectedNodeTrafficProfile.SelectionLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           Text="{Binding SelectedNodeTrafficProfile.RoleSummary}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="4"
                                        Padding="12"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="Edges" />

                                        <WrapPanel Grid.Row="2">
                                            <Button Content="Add Edge" Click="AddEdge_Click" />
                                            <Button Content="Open Edge Editor..." Click="EditEdges_Click" />
                                            <Button Content="Remove Selected" Click="RemoveEdge_Click" />
                                        </WrapPanel>

                                        <DataGrid Grid.Row="4"
                                                  MinHeight="150"
                                                  ItemsSource="{Binding Edges}"
                                                  SelectedItem="{Binding SelectedEdge, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Id, Mode=TwoWay}" Header="Id" Width="70" />
                                                <DataGridTemplateColumn Header="From" Width="110">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding FromNodeId}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                                            <ComboBox ItemsSource="{Binding DataContext.NodeIdOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding FromNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="To" Width="110">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding ToNodeId}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EdgeViewModel}">
                                                            <ComboBox ItemsSource="{Binding DataContext.NodeIdOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding ToNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Binding="{Binding Time, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="Time" Width="68" />
                                                <DataGridTextColumn Binding="{Binding Cost, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="Cost" Width="68" />
                                                <DataGridTextColumn Binding="{Binding Capacity, Mode=TwoWay, StringFormat={}{0:0.##}}" Header="Capacity" Width="80" />
                                                <DataGridCheckBoxColumn Binding="{Binding IsBidirectional, Mode=TwoWay}" Header="2-way" Width="60" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                    </TabControl>

                    <TextBlock Grid.Row="2"
                               FontSize="13"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </Grid>
            </Expander>
        </Border>
    </Grid>
</Window>
