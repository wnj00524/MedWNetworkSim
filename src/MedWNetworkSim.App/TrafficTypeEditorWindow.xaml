<Window x:Class="MedWNetworkSim.App.TrafficTypeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Traffic Type Editor"
        Width="980"
        Height="700"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Traffic Type Editor" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Add, rename, and edit traffic types in a full-size editor. Changes update the shared network immediately, including routing preference, allocation mode, and capacity bidding defaults."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Traffic Types" />

                    <WrapPanel Grid.Row="2">
                        <Button Content="Add Traffic Type" Click="AddTrafficType_Click" />
                        <Button Content="Remove Selected" Click="RemoveTrafficType_Click" />
                    </WrapPanel>

                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding TrafficDefinitions}"
                              SelectedItem="{Binding SelectedTrafficDefinition, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              MinHeight="360"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Name" Width="130" />
                            <DataGridTemplateColumn Header="Preference" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding RoutingPreference}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="112"
                                                  ItemsSource="{Binding DataContext.RoutingPreferences, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding RoutingPreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Allocation Mode" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding AllocationModeLabel}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="170"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  ItemsSource="{Binding DataContext.AllocationModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding AllocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding CapacityBidPerUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Header="Bid / Unit" Width="105" />
                            <DataGridTemplateColumn Header="Route Model" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding RouteChoiceModel}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="160"
                                                  ItemsSource="{Binding DataContext.RouteChoiceModels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding RouteChoiceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Split Policy" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding FlowSplitPolicy}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Padding="2"
                                                  MinWidth="120"
                                                  ItemsSource="{Binding DataContext.FlowSplitPolicies, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding FlowSplitPolicy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Description" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Selected Traffic Type" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Traffic Type" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SelectedTrafficDefinition.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Preference" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  ItemsSource="{Binding RoutingPreferences}"
                                  SelectedItem="{Binding SelectedTrafficDefinition.RoutingPreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Allocation Mode" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  ItemsSource="{Binding AllocationModeOptions}"
                                  SelectedValue="{Binding SelectedTrafficDefinition.AllocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Bid / Unit" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="1"
                                 Text="{Binding SelectedTrafficDefinition.CapacityBidPerUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="8"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Route Model" />
                        <ComboBox Grid.Row="8"
                                  Grid.Column="1"
                                  ItemsSource="{Binding RouteChoiceModels}"
                                  SelectedItem="{Binding SelectedTrafficDefinition.RouteChoiceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="10"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Flow Split" />
                        <ComboBox Grid.Row="10"
                                  Grid.Column="1"
                                  ItemsSource="{Binding FlowSplitPolicies}"
                                  SelectedItem="{Binding SelectedTrafficDefinition.FlowSplitPolicy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="12"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Candidate Routes" />
                        <TextBox Grid.Row="12"
                                 Grid.Column="1"
                                 Text="{Binding SelectedTrafficDefinition.MaxCandidateRoutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="14"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Priority" />
                        <TextBox Grid.Row="14"
                                 Grid.Column="1"
                                 Text="{Binding SelectedTrafficDefinition.Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="16"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Congestion Sensitivity" />
                        <TextBox Grid.Row="16"
                                 Grid.Column="1"
                                 Text="{Binding SelectedTrafficDefinition.CongestionSensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="18"
                                    Grid.ColumnSpan="2"
                                    Visibility="{Binding SelectedTrafficDefinition.IsStochasticUserResponsive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="Stochastic Settings" />
                            <UniformGrid Margin="0,6,0,0"
                                         Columns="2">
                                <TextBox ToolTip="Information Accuracy"
                                         Text="{Binding SelectedTrafficDefinition.InformationAccuracy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox ToolTip="Route Diversity"
                                         Text="{Binding SelectedTrafficDefinition.RouteDiversity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox ToolTip="Reroute Threshold"
                                         Text="{Binding SelectedTrafficDefinition.RerouteThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox ToolTip="Stickiness"
                                         Text="{Binding SelectedTrafficDefinition.Stickiness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </UniformGrid>
                        </StackPanel>

                        <CheckBox Grid.Row="20"
                                  Grid.ColumnSpan="2"
                                  Content="Internalize congestion"
                                  IsChecked="{Binding SelectedTrafficDefinition.InternalizeCongestion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Visibility="{Binding SelectedTrafficDefinition.IsSystemOptimal, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Grid.Row="22"
                                   VerticalAlignment="Top"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Description" />
                        <TextBox Grid.Row="22"
                                 Grid.Column="1"
                                 MinHeight="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding SelectedTrafficDefinition.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Border Grid.Row="4"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding SelectedTrafficDefinition.AllocationModeHelpText}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="6"
                            Padding="12"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Tip: the main bottom editor remains available for quick review, but this window is the recommended place to edit multiple traffic types." />
            <Button DockPanel.Dock="Right"
                    Margin="12,0,0,0"
                    Content="Close"
                    Click="Close_Click" />
        </DockPanel>
    </Grid>
</Window>
