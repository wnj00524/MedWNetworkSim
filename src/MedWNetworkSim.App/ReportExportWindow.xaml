<Window x:Class="MedWNetworkSim.App.ReportExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Export Reports"
        Style="{StaticResource DialogChromeWindowStyle}"
        Width="660"
        Height="500"
        MinWidth="600"
        MinHeight="440"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                           Text="Export report" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HelperTextStyle}"
                           Text="Choose what to export, which format to use, and where to save it."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Report type" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ExportKindOptions}"
                                  SelectedItem="{Binding SelectedExportKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding ExportDescription}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Report File" />
                        <TextBox Grid.Column="1"
                                 MinWidth="300"
                                 Text="{Binding ReportPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Margin="12,0,0,0"
                                Content="Browse..."
                                Click="Browse_Click" />
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Report Format" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding FormatOptions}"
                                  SelectedItem="{Binding SelectedFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Grid.Row="8"
                          Visibility="{Binding IsTimelineExport, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Timeline Periods" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding TimelinePeriodsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <WrapPanel Grid.Row="10">
                        <Button Content="{Binding ExportButtonText}"
                                IsEnabled="{Binding CanExport}"
                                Click="ExportReport_Click" />
                    </WrapPanel>

                    <Border Grid.Row="12"
                            Padding="12"
                            Background="{DynamicResource InfoPanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="Save destination" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="Use Browse to choose both the file name and the save location. The selected format updates the expected file extension automatically." />
                        </StackPanel>
                    </Border>

                    <DockPanel Grid.Row="14">
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="HTML is best for a polished readable report. CSV is best for spreadsheet analysis. JSON is best for machine-readable integrations." />
                        <Button DockPanel.Dock="Right"
                                Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Close"
                                Click="Close_Click" />
                    </DockPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
