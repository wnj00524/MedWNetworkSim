<Window x:Class="MedWNetworkSim.App.IntroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedW Network Simulator"
        Width="960"
        Height="540"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black"
        AllowsTransparency="False">
    <Border BorderBrush="#33000000"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Image Source="Assets/logo.jpg"
                   Stretch="UniformToFill"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Border VerticalAlignment="Bottom"
                    Background="#7F000000"
                    Padding="24,16">
                <TextBlock Text="Placeholder intro image"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>
    </Border>
</Window>
