<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,*" ColumnDefinitions="320,*" RowSpacing="12" ColumnSpacing="12" Margin="12">
    <WrapPanel Grid.ColumnSpan="2">
      <Button Content="Add Firm" Command="{Binding AddFirmActorCommand}" />
      <Button Content="Add Government" Command="{Binding AddGovernmentActorCommand}" />
      <Button Content="Add Logistics" Command="{Binding AddLogisticsPlannerActorCommand}" />
      <Button Content="Duplicate" Command="{Binding DuplicateSelectedActorCommand}" />
      <Button Content="Remove" Command="{Binding RemoveSelectedActorCommand}" />
    </WrapPanel>
    <StackPanel Grid.Row="1" Spacing="8">
      <TextBlock Text="Actor Cards" FontWeight="Bold" />
      <TextBox Text="{Binding AgentSearchText}" Watermark="Search" />
      <ListBox ItemsSource="{Binding FilteredSimulationActors}"
               SelectedItem="{Binding SelectedSimulationActor}" />
    </StackPanel>
    <ScrollViewer Grid.Row="1" Grid.Column="1">
      <StackPanel Spacing="8">
        <TextBlock Text="Editor Drawer" FontWeight="Bold" />
        <TextBlock Text="{Binding ActorStatusMessage}" TextWrapping="Wrap" />
        <TextBlock Text="{Binding SelectedActorTrafficScopeText}" TextWrapping="Wrap" />
        <TextBox Text="{Binding ActorNameText}" Watermark="Name" />
        <TextBox Text="{Binding ActorBudgetText}" Watermark="Budget" />
        <TextBox Text="{Binding ActorCashText}" Watermark="Cash" />
        <CheckBox Content="Enabled" IsChecked="{Binding ActorIsEnabled}" />
        <CheckBox Content="Allow all traffic" IsChecked="{Binding ActorAllowAllTrafficTypes}" />
        <ItemsControl ItemsSource="{Binding ActorPermissionRows}" />
        <TextBlock Text="{Binding ActorValidationText}" TextWrapping="Wrap" />
        <WrapPanel>
          <Button Content="Apply" Command="{Binding ApplySelectedActorCommand}" />
          <Button Content="Preview" Command="{Binding PreviewActorActionsCommand}" />
          <Button Content="Run step" Command="{Binding RunActorStepCommand}" />
          <Button Content="Export logs" Command="{Binding ExportAgentLogsCommand}" />
        </WrapPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
