<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:MedWNetworkSim.UI"
             xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
             x:Class="MedWNetworkSim.UI.Views.AnalyticsView">
  <Grid RowDefinitions="Auto,*" RowSpacing="12" Margin="12">
    <WrapPanel>
      <ComboBox x:Name="TrafficTypeFilterComboBox"
                MinWidth="180"
                automation:AutomationProperties.Name="Traffic type"
                ItemsSource="{Binding SankeyTrafficTypeNameOptions}"
                SelectedItem="{Binding SankeyTrafficTypeFilterSelection, Mode=TwoWay}" />
      <CheckBox Content="Show unmet demand"
                IsChecked="{Binding VisualisationState.ShowUnmetDemand}" />
      <CheckBox Content="Show capacity utilisation"
                IsChecked="{Binding VisualisationState.ShowCapacityUtilisation}" />
      <CheckBox Content="Collapse minor flows"
                IsChecked="{Binding VisualisationState.CollapseMinorFlows}" />
    </WrapPanel>
    <Grid Grid.Row="1" ColumnDefinitions="*,330" ColumnSpacing="12">
      <Grid RowDefinitions="1.1*,0.9*" RowSpacing="10">
        <ui:GraphCanvasControl ViewModel="{Binding}" RenderModeOverride="Sankey" />
        <ui:GraphCanvasControl Grid.Row="1" ViewModel="{Binding}" RenderModeOverride="Analytics" />
      </Grid>
      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="10">
          <TextBlock Text="Top Issues" FontWeight="Bold" />
          <ListBox ItemsSource="{Binding TopIssues}"
                   SelectedItem="{Binding SelectedTopIssue}" />
          <TextBlock Text="Node Pressure" FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding NodePressureReports}" />
          <TextBlock Text="Route Pressure" FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding RouteReports}" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
